$C = "../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Left: 0, Right: 0, Bottom: 6, Height: 44);
  Background: #1a2530(0.95);

  Group #AccentBar {
    Anchor: (Width: 8, Top: 0, Bottom: 0);

    Group #AccentGold { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #ffd700; Visible: false; }
    Group #AccentSilver { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #c0c0c0; Visible: false; }
    Group #AccentBronze { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #cd7f32; Visible: false; }
    Group #AccentDefault { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #9fb0ba; Visible: true; }
  }

  Group #ContentRow {
    FlexWeight: 1;
    Padding: (Left: 12, Right: 12, Top: 12);
    LayoutMode: Left;

    Label #Rank {
      Anchor: (Width: 46);
      Style: (
        FontSize: 14,
        RenderBold: true,
        TextColor: #f0f4f8
      );
      Text: "1";
    }

    Label #PlayerName {
      FlexWeight: 1;
      Style: (
        FontSize: 14,
        TextColor: #cfd7dc
      );
      Text: "Player";
    }

    Label #Time {
      Anchor: (Width: 74, Right: 0);
      Style: (
        FontSize: 13,
        RenderBold: true,
        TextColor: #9fb0ba
      );
      Text: "0.00s";
    }
  }
}
