$C = "../Common.ui";

$C.@PageOverlay {
  SceneBlur {}

  Group #GameOverWindow {
    Anchor: (Width: 460, Height: 300);
    LayoutMode: Top;
    Background: #0d1620(0.95);
    OutlineColor: #ffffff(0.06);
    OutlineSize: 1;

    // === HEADER ===
    Group #Header {
      Anchor: (Left: 0, Right: 0, Height: 42);
      LayoutMode: Full;
      Background: #0a1018;

      Group {
        Anchor: (Left: 0, Right: 0, Top: 0, Height: 2);
        Background: #ef4444;
      }

      Label {
        Anchor: (Left: 20, Top: 12, Width: 200, Height: 22);
        Style: (FontSize: 15, TextColor: #f0f4f8, RenderBold: true);
        Text: "PURGE COMPLETE";
      }

      Label #ReasonLabel {
        Anchor: (Right: 20, Top: 12, Width: 200, Height: 22);
        Style: (FontSize: 13, TextColor: #9fb0ba, HorizontalAlignment: End);
        Text: "";
      }
    }

    // === STATS GRID (2x2) ===
    Group #StatsArea {
      Anchor: (Left: 0, Right: 0);
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 16, Bottom: 8);

      // Row 1
      Group #Row1 {
        Anchor: (Left: 0, Right: 0, Height: 80);
        LayoutMode: Left;

        // Wave Reached
        Group #WaveCard {
          FlexWeight: 1;
          Anchor: (Top: 0, Bottom: 0, Right: 10);
          LayoutMode: Top;
          Background: #ffffff(0.03);
          OutlineColor: #ffffff(0.04);
          OutlineSize: 1;

          Group { FlexWeight: 1; }

          Label {
            Anchor: (Left: 0, Right: 0);
            Style: (FontSize: 12, TextColor: #7d8c96, RenderBold: true, HorizontalAlignment: Center);
            Text: "WAVE REACHED";
          }

          Label #WaveValue {
            Anchor: (Left: 0, Right: 0, Top: 4);
            Style: (FontSize: 28, TextColor: #f0f4f8, RenderBold: true, HorizontalAlignment: Center);
            Text: "0";
          }

          Group { FlexWeight: 1; }
        }

        // Kills
        Group #KillsCard {
          FlexWeight: 1;
          Anchor: (Top: 0, Bottom: 0);
          LayoutMode: Top;
          Background: #ffffff(0.03);
          OutlineColor: #ffffff(0.04);
          OutlineSize: 1;

          Group { FlexWeight: 1; }

          Label {
            Anchor: (Left: 0, Right: 0);
            Style: (FontSize: 12, TextColor: #7d8c96, RenderBold: true, HorizontalAlignment: Center);
            Text: "KILLS";
          }

          Label #KillsValue {
            Anchor: (Left: 0, Right: 0, Top: 4);
            Style: (FontSize: 28, TextColor: #f0f4f8, RenderBold: true, HorizontalAlignment: Center);
            Text: "0";
          }

          Group { FlexWeight: 1; }
        }
      }

      // Row 2
      Group #Row2 {
        Anchor: (Left: 0, Right: 0, Top: 10, Height: 80);
        LayoutMode: Left;

        // Scrap Earned
        Group #ScrapCard {
          FlexWeight: 1;
          Anchor: (Top: 0, Bottom: 0, Right: 10);
          LayoutMode: Top;
          Background: #ffffff(0.03);
          OutlineColor: #ffffff(0.04);
          OutlineSize: 1;

          Group { FlexWeight: 1; }

          Label {
            Anchor: (Left: 0, Right: 0);
            Style: (FontSize: 12, TextColor: #7d8c96, RenderBold: true, HorizontalAlignment: Center);
            Text: "SCRAP EARNED";
          }

          Label #ScrapValue {
            Anchor: (Left: 0, Right: 0, Top: 4);
            Style: (FontSize: 28, TextColor: #f0f4f8, RenderBold: true, HorizontalAlignment: Center);
            Text: "0";
          }

          Group { FlexWeight: 1; }
        }

        // Best Combo
        Group #ComboCard {
          FlexWeight: 1;
          Anchor: (Top: 0, Bottom: 0);
          LayoutMode: Top;
          Background: #ffffff(0.03);
          OutlineColor: #ffffff(0.04);
          OutlineSize: 1;

          Group { FlexWeight: 1; }

          Label {
            Anchor: (Left: 0, Right: 0);
            Style: (FontSize: 12, TextColor: #7d8c96, RenderBold: true, HorizontalAlignment: Center);
            Text: "BEST COMBO";
          }

          Label #ComboValue {
            Anchor: (Left: 0, Right: 0, Top: 4);
            Style: (FontSize: 28, TextColor: #ef4444, RenderBold: true, HorizontalAlignment: Center);
            Text: "x0";
          }

          Group { FlexWeight: 1; }
        }
      }
    }

    // === CLOSE BUTTON ===
    Group #CloseWrap {
      Anchor: (Left: 0, Right: 0, Height: 48);
      LayoutMode: Full;
      Padding: (Left: 20, Right: 20, Top: 4, Bottom: 12);

      TextButton #CloseButton {
        Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
        Text: "Close";
        Style: TextButtonStyle(
          Default: (
            Background: #ffffff(0.06),
            LabelStyle: (FontSize: 14, TextColor: #9fb0ba, HorizontalAlignment: Center, VerticalAlignment: Center)
          ),
          Hovered: (
            Background: #ffffff(0.12),
            LabelStyle: (FontSize: 14, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
          ),
          Pressed: (
            Background: #ffffff(0.04),
            LabelStyle: (FontSize: 14, TextColor: #9fb0ba, HorizontalAlignment: Center, VerticalAlignment: Center)
          ),
          Sounds: $C.@ButtonSounds,
        );
      }
    }
  }
}
