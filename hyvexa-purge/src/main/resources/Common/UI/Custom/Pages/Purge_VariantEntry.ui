$C = "../Common.ui";

Group {
  Anchor: (Width: 290, Height: 132);
  Padding: (Left: 3, Right: 3, Top: 3, Bottom: 3);

  Group {
    Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
    LayoutMode: Top;
    Background: $C.@InputBoxBackground;
    Padding: (Left: 8, Right: 8, Top: 6, Bottom: 6);

    // Row 1: Name + Edit + Delete
    Group {
      LayoutMode: Left;
      Anchor: (Left: 0, Right: 0, Height: 22);

      Label #VariantLabel {
        FlexWeight: 1;
        Style: (FontSize: 13, RenderBold: true, TextColor: #10b981, VerticalAlignment: Center);
        Text: "Normal";
      }

      TextButton #EditNameButton {
        Anchor: (Width: 40, Height: 20);
        Text: "Edit";
        Style: TextButtonStyle(
          Default: (Background: #143042, LabelStyle: (FontSize: 10, TextColor: #7dd3fc, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #1d4359, LabelStyle: (FontSize: 10, TextColor: #bae6fd, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #102734, LabelStyle: (FontSize: 10, TextColor: #7dd3fc, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Sounds: $C.@ButtonSounds,
        );
      }

      Group { Anchor: (Width: 4); }

      TextButton #DeleteButton {
        Anchor: (Width: 24, Height: 20);
        Text: "X";
        Style: TextButtonStyle(
          Default: (Background: #3b1219, LabelStyle: (FontSize: 11, TextColor: #ef4444, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #5c1d28, LabelStyle: (FontSize: 11, TextColor: #f87171, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #2d0f14, LabelStyle: (FontSize: 11, TextColor: #ef4444, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Sounds: $C.@ButtonSounds,
        );
      }
    }

    // Row 2: Key
    Label #VariantKey {
      Anchor: (Top: 1, Height: 14);
      Style: (FontSize: 10, TextColor: #6b7b8a);
      Text: "NORMAL";
    }

    // Row 3: HP + DMG
    Group {
      LayoutMode: Left;
      Anchor: (Left: 0, Right: 0, Height: 22, Top: 4);

      Label {
        Anchor: (Width: 22);
        Style: (FontSize: 11, TextColor: #fca5a5, VerticalAlignment: Center);
        Text: "HP";
      }

      TextButton #HpMinusButton {
        Anchor: (Width: 20, Height: 20);
        Text: "-";
        Style: TextButtonStyle(
          Default: (Background: #32131a, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #4a1f29, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fecaca, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #230d12, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Sounds: $C.@ButtonSounds,
        );
      }

      Label #HpValue {
        Anchor: (Width: 30);
        Style: (FontSize: 11, RenderBold: true, TextColor: #fee2e2, HorizontalAlignment: Center, VerticalAlignment: Center);
        Text: "50";
      }

      TextButton #HpPlusButton {
        Anchor: (Width: 20, Height: 20);
        Text: "+";
        Style: TextButtonStyle(
          Default: (Background: #32131a, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #4a1f29, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fecaca, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #230d12, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Sounds: $C.@ButtonSounds,
        );
      }

      Group { Anchor: (Width: 12); }

      Label {
        Anchor: (Width: 28);
        Style: (FontSize: 11, TextColor: #fdba74, VerticalAlignment: Center);
        Text: "DMG";
      }

      TextButton #DmgMinusButton {
        Anchor: (Width: 20, Height: 20);
        Text: "-";
        Style: TextButtonStyle(
          Default: (Background: #2a1f0a, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fdba74, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #3d2e0f, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fed7aa, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #1f1707, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fdba74, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Sounds: $C.@ButtonSounds,
        );
      }

      Label #DmgValue {
        Anchor: (Width: 30);
        Style: (FontSize: 11, RenderBold: true, TextColor: #ffedd5, HorizontalAlignment: Center, VerticalAlignment: Center);
        Text: "20";
      }

      TextButton #DmgPlusButton {
        Anchor: (Width: 20, Height: 20);
        Text: "+";
        Style: TextButtonStyle(
          Default: (Background: #2a1f0a, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fdba74, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #3d2e0f, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fed7aa, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #1f1707, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fdba74, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Sounds: $C.@ButtonSounds,
        );
      }
    }

    // Row 4: Speed + Scrap
    Group {
      LayoutMode: Left;
      Anchor: (Left: 0, Right: 0, Height: 22, Top: 2);

      Label {
        Anchor: (Width: 22);
        Style: (FontSize: 11, TextColor: #93c5fd, VerticalAlignment: Center);
        Text: "Spd";
      }

      TextButton #SpeedMinusButton {
        Anchor: (Width: 20, Height: 20);
        Text: "-";
        Style: TextButtonStyle(
          Default: (Background: #0b1e33, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #93c5fd, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #123154, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #bfdbfe, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #081625, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #93c5fd, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Sounds: $C.@ButtonSounds,
        );
      }

      Label #SpeedValue {
        Anchor: (Width: 36);
        Style: (FontSize: 11, RenderBold: true, TextColor: #dbeafe, HorizontalAlignment: Center, VerticalAlignment: Center);
        Text: "100%";
      }

      TextButton #SpeedPlusButton {
        Anchor: (Width: 20, Height: 20);
        Text: "+";
        Style: TextButtonStyle(
          Default: (Background: #0b1e33, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #93c5fd, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #123154, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #bfdbfe, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #081625, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #93c5fd, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Sounds: $C.@ButtonSounds,
        );
      }

      Group { Anchor: (Width: 6); }

      Label {
        Anchor: (Width: 28);
        Style: (FontSize: 11, TextColor: #fbbf24, VerticalAlignment: Center);
        Text: "Scr";
      }

      TextButton #ScrapMinusButton {
        Anchor: (Width: 20, Height: 20);
        Text: "-";
        Style: TextButtonStyle(
          Default: (Background: #2a2008, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fbbf24, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #3d300c, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fde68a, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #1f1806, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fbbf24, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Sounds: $C.@ButtonSounds,
        );
      }

      Label #ScrapValue {
        Anchor: (Width: 30);
        Style: (FontSize: 11, RenderBold: true, TextColor: #fef3c7, HorizontalAlignment: Center, VerticalAlignment: Center);
        Text: "10";
      }

      TextButton #ScrapPlusButton {
        Anchor: (Width: 20, Height: 20);
        Text: "+";
        Style: TextButtonStyle(
          Default: (Background: #2a2008, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fbbf24, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #3d300c, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fde68a, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #1f1806, LabelStyle: (FontSize: 13, RenderBold: true, TextColor: #fbbf24, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Sounds: $C.@ButtonSounds,
        );
      }
    }

    // Row 5: Mob type button
    Group {
      Anchor: (Left: 0, Right: 0, Height: 22, Top: 4);
      TextButton #NpcTypeButton {
        Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
        Text: "Zombie";
        Style: TextButtonStyle(
          Default: (Background: #1e1541, LabelStyle: (FontSize: 10, TextColor: #c4b5fd, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #2e2060, LabelStyle: (FontSize: 10, TextColor: #ddd6fe, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #160f30, LabelStyle: (FontSize: 10, TextColor: #c4b5fd, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Sounds: $C.@ButtonSounds,
        );
      }
    }
  }
}
