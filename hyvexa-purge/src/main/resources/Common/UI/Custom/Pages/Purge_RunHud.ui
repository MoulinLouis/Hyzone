$C = "../Common.ui";

$C.@PageOverlay {
  Background: #000000(0.0);
  Group #HudLayer {
    Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);

    Group #WaveStatusRow {
      Anchor: (Top: 30, Left: 0, Right: 0, Height: 120);
      LayoutMode: Left;
      Visible: false;

      Group { FlexWeight: 1; }

      Group #WaveStatusRoot {
        Anchor: (Width: 360, Height: 120);
        LayoutMode: Top;

        Label #WaveLabel {
          Anchor: (Height: 46);
          Style: (
            FontSize: 34,
            HorizontalAlignment: Center,
            RenderBold: true,
            TextColor: #e7f1f4
          );
          Text: "WAVE 1";
        }

        Label #ZombieCountLabel {
          Anchor: (Top: 4, Height: 32);
          Style: (
            FontSize: 24,
            HorizontalAlignment: Center,
            RenderBold: true,
            TextColor: #d9e6ec
          );
          Text: "";
        }
      }

      Group { FlexWeight: 1; }
    }

    Group #KillMeter {
      Anchor: (Left: 20, Top: 170, Width: 200, Height: 200);
      LayoutMode: Top;
      Background: #0d1620(0.92);
      OutlineColor: #ffffff(0.06);
      OutlineSize: 1;
      Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
      Visible: false;

      Label #KmTitle {
        Anchor: (Height: 18);
        Style: (
          FontSize: 13,
          TextColor: #4ade80(0.7),
          RenderUppercase: true,
          LetterSpacing: 2,
          RenderBold: true
        );
        Text: "KILLS";
      }

      Group #KmSep {
        Anchor: (Left: 0, Width: 30, Height: 2, Top: 4);
        Background: #4ade80;
      }

      Group #KmRow0 {
        Anchor: (Left: 0, Right: 0, Top: 6, Height: 22);
        LayoutMode: Left;
        Visible: false;

        Label #KmName0 {
          FlexWeight: 1;
          Anchor: (Height: 22);
          Style: (FontSize: 15, TextColor: #e7f1f4, VerticalAlignment: Center);
          Text: "";
        }
        Label #KmKills0 {
          Anchor: (Height: 22);
          Style: (FontSize: 15, TextColor: #4ade80, RenderBold: true, VerticalAlignment: Center);
          Text: "0";
        }
      }

      Group #KmRow1 {
        Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
        LayoutMode: Left;
        Visible: false;

        Label #KmName1 {
          FlexWeight: 1;
          Anchor: (Height: 22);
          Style: (FontSize: 15, TextColor: #e7f1f4, VerticalAlignment: Center);
          Text: "";
        }
        Label #KmKills1 {
          Anchor: (Height: 22);
          Style: (FontSize: 15, TextColor: #4ade80, RenderBold: true, VerticalAlignment: Center);
          Text: "0";
        }
      }

      Group #KmRow2 {
        Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
        LayoutMode: Left;
        Visible: false;

        Label #KmName2 {
          FlexWeight: 1;
          Anchor: (Height: 22);
          Style: (FontSize: 15, TextColor: #e7f1f4, VerticalAlignment: Center);
          Text: "";
        }
        Label #KmKills2 {
          Anchor: (Height: 22);
          Style: (FontSize: 15, TextColor: #4ade80, RenderBold: true, VerticalAlignment: Center);
          Text: "0";
        }
      }

      Group #KmRow3 {
        Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
        LayoutMode: Left;
        Visible: false;

        Label #KmName3 {
          FlexWeight: 1;
          Anchor: (Height: 22);
          Style: (FontSize: 15, TextColor: #e7f1f4, VerticalAlignment: Center);
          Text: "";
        }
        Label #KmKills3 {
          Anchor: (Height: 22);
          Style: (FontSize: 15, TextColor: #4ade80, RenderBold: true, VerticalAlignment: Center);
          Text: "0";
        }
      }

      Group #KmRow4 {
        Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
        LayoutMode: Left;
        Visible: false;

        Label #KmName4 {
          FlexWeight: 1;
          Anchor: (Height: 22);
          Style: (FontSize: 15, TextColor: #e7f1f4, VerticalAlignment: Center);
          Text: "";
        }
        Label #KmKills4 {
          Anchor: (Height: 22);
          Style: (FontSize: 15, TextColor: #4ade80, RenderBold: true, VerticalAlignment: Center);
          Text: "0";
        }
      }
    }

    Group #MissionPanel {
      Anchor: (Left: 20, Top: 40, Width: 280, Height: 180);
      LayoutMode: Top;
      Background: #0d1620(0.92);
      OutlineColor: #ffffff(0.06);
      OutlineSize: 1;
      Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);

      Group #MissionHeader {
        Anchor: (Left: 0, Right: 0, Height: 18);
        LayoutMode: Left;

        Label #MissionTitle {
          Anchor: (Height: 18);
          Style: (
            FontSize: 13,
            TextColor: #f59e0b(0.7),
            RenderUppercase: true,
            LetterSpacing: 2,
            RenderBold: true
          );
          Text: "DAILY MISSIONS";
        }

        Group { FlexWeight: 1; }

        Label #MissionTimer {
          Anchor: (Height: 18);
          Style: (FontSize: 12, TextColor: #8b9db0, VerticalAlignment: Center);
          Text: "";
        }
      }

      Group #MissionSep {
        Anchor: (Left: 0, Width: 30, Height: 2, Top: 4);
        Background: #f59e0b;
      }

      Group #MissionRow0 {
        Anchor: (Left: 0, Right: 0, Top: 6, Height: 36);
        LayoutMode: Top;

        Group #MissionRow0Top {
          Anchor: (Left: 0, Right: 0, Height: 18);
          LayoutMode: Left;

          Label #MissionDesc0 {
            FlexWeight: 1;
            Anchor: (Height: 18);
            Style: (FontSize: 14, TextColor: #e7f1f4, VerticalAlignment: Center);
            Text: "";
          }
          Label #MissionReward0 {
            Anchor: (Height: 18);
            Style: (FontSize: 13, TextColor: #f59e0b, RenderBold: true, VerticalAlignment: Center);
            Text: "";
          }
        }

        Label #MissionProg0 {
          Anchor: (Left: 0, Top: 2, Height: 16);
          Style: (FontSize: 12, TextColor: #8b9db0);
          Text: "";
        }
      }

      Group #MissionRow1 {
        Anchor: (Left: 0, Right: 0, Top: 4, Height: 36);
        LayoutMode: Top;

        Group #MissionRow1Top {
          Anchor: (Left: 0, Right: 0, Height: 18);
          LayoutMode: Left;

          Label #MissionDesc1 {
            FlexWeight: 1;
            Anchor: (Height: 18);
            Style: (FontSize: 14, TextColor: #e7f1f4, VerticalAlignment: Center);
            Text: "";
          }
          Label #MissionReward1 {
            Anchor: (Height: 18);
            Style: (FontSize: 13, TextColor: #f59e0b, RenderBold: true, VerticalAlignment: Center);
            Text: "";
          }
        }

        Label #MissionProg1 {
          Anchor: (Left: 0, Top: 2, Height: 16);
          Style: (FontSize: 12, TextColor: #8b9db0);
          Text: "";
        }
      }

      Group #MissionRow2 {
        Anchor: (Left: 0, Right: 0, Top: 4, Height: 36);
        LayoutMode: Top;

        Group #MissionRow2Top {
          Anchor: (Left: 0, Right: 0, Height: 18);
          LayoutMode: Left;

          Label #MissionDesc2 {
            FlexWeight: 1;
            Anchor: (Height: 18);
            Style: (FontSize: 14, TextColor: #e7f1f4, VerticalAlignment: Center);
            Text: "";
          }
          Label #MissionReward2 {
            Anchor: (Height: 18);
            Style: (FontSize: 13, TextColor: #f59e0b, RenderBold: true, VerticalAlignment: Center);
            Text: "";
          }
        }

        Label #MissionProg2 {
          Anchor: (Left: 0, Top: 2, Height: 16);
          Style: (FontSize: 12, TextColor: #8b9db0);
          Text: "";
        }
      }
    }

    Group #RunHudRoot {
      Anchor: (Right: 20, Top: 400, Width: 284, Height: 406);
      LayoutMode: Left;

      Group #InfoAccentBar {
        Anchor: (Width: 4, Top: 0, Bottom: 0);
        Background: #4ade80;
      }

      Group #InfoBox {
        FlexWeight: 1;
        Anchor: (Top: 0, Bottom: 0);
        Background: #0d1620(0.95);
        OutlineColor: #ffffff(0.06);
        OutlineSize: 1;

        Group #InfoBoxFlow {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          LayoutMode: Top;

          Group #InfoImageBanner {
            Anchor: (Width: 200, Height: 94, Top: 18);
            Background: (TexturePath: "../Textures/logo_hyvexa.png");
          }

          Group #InfoContent {
            Anchor: (Left: 0, Right: 0);
            LayoutMode: Top;
            Padding: (Left: 14, Right: 14, Top: 12, Bottom: 14);

            Label #PlayerNameText {
              Style: (
                FontSize: 13,
                TextColor: #4ade80(0.7),
                RenderUppercase: true,
                LetterSpacing: 2,
                RenderBold: true
              );
              Text: "Purge";
            }

            Group #InfoSep {
              Anchor: (Left: 0, Width: 30, Height: 2, Top: 6);
              Background: #4ade80;
            }

            Label #InfoHintText {
              Anchor: (Top: 10, Left: 0, Right: 0);
              Style: (
                FontSize: 16,
                TextColor: #cfd7dc,
                Wrap: true
              );
              Text: "Zombie Survival - Survive the waves!";
            }

            Group #PlayerVexaRow {
              Anchor: (Left: 0, Right: 0, Top: 8, Height: 32);
              LayoutMode: Left;

              Group #VexaIcon {
                Anchor: (Width: 26, Height: 26, Top: 3);
                Background: (TexturePath: "../Textures/vexa.png");
              }
              Group { Anchor: (Width: 8); }
              Label #PlayerVexaValue {
                Anchor: (Height: 30);
                Style: (FontSize: 22, TextColor: #22c55e, RenderBold: true, VerticalAlignment: Center);
                Text: "0";
              }
            }

            Label #InfoIpText {
              Anchor: (Top: 6);
              Style: (
                FontSize: 16,
                TextColor: #4ade80(0.8),
                RenderBold: true
              );
              Text: "play.hyvexa.com (/vote)";
            }

            Group #InfoDivider {
              Anchor: (Left: 0, Right: 0, Height: 1, Top: 10);
              Background: #ffffff(0.06);
            }

            Label #InfoSupportTitle {
              Anchor: (Top: 10);
              Style: (
                FontSize: 15,
                TextColor: #ffd166,
                RenderBold: true
              );
              Text: "Support Hyvexa (/store)";
            }

            Group #InfoSupportRow1 {
              Anchor: (Left: 0, Right: 0, Top: 6, Height: 20);
              LayoutMode: Left;

              Group {
                Anchor: (Width: 18, Height: 18);
                Background: (TexturePath: "../Textures/star.png");
              }
              Group { Anchor: (Width: 6); }
              Label {
                Style: (FontSize: 16, TextColor: #e7f1f4);
                Text: "Exclusive Ranks";
              }
            }

            Group #InfoSupportRow2 {
              Anchor: (Left: 0, Right: 0, Top: 4, Height: 20);
              LayoutMode: Left;

              Group {
                Anchor: (Width: 18, Height: 18);
                Background: (TexturePath: "../Textures/storm.png");
              }
              Group { Anchor: (Width: 6); }
              Label {
                Style: (FontSize: 16, TextColor: #e7f1f4);
                Text: "Speed Boost";
              }
            }

            Label #InfoStoreLink {
              Anchor: (Top: 8, Left: 0, Right: 0);
              Style: (
                FontSize: 16,
                TextColor: #ffd166,
                RenderBold: true,
                HorizontalAlignment: Center
              );
              Text: "store.hyvexa.com";
            }
          }
        }

        Group #PlayerCountRow {
          Anchor: (Left: 0, Right: 0, Top: 8, Height: 20);
          LayoutMode: Right;
          Padding: (Right: 12);

          Label #PlayerCountText {
            Style: (
              FontSize: 14,
              TextColor: #8b9db0,
              RenderBold: true
            );
            Text: "0";
          }
          Group { Anchor: (Width: 4); }
          Group #PlayerCountIcon {
            Anchor: (Width: 14, Height: 14);
            Background: (TexturePath: "../Textures/user.png");
          }
        }
      }
    }

    Group #ComboRoot {
      Anchor: (Top: 160, Left: 0, Right: 0, Height: 50);
      LayoutMode: Left;
      Visible: false;

      Group { FlexWeight: 1; }

      Group #ComboBox {
        Anchor: (Width: 200, Height: 50);
        LayoutMode: Top;

        Label #ComboLabel {
          Anchor: (Height: 30);
          Style: (
            FontSize: 24,
            HorizontalAlignment: Center,
            RenderBold: true,
            TextColor: #f59e0b
          );
          Text: "COMBO x2";
        }

        ProgressBar #ComboBar {
          Anchor: (Left: 10, Right: 10, Height: 6);
          Value: 1;
          Bar: #f59e0b;
          Background: #f59e0b(0.15);
        }
      }

      Group { FlexWeight: 1; }
    }

    Group #PlayerHealthRow {
      Anchor: (Bottom: 135, Left: 0, Right: 320, Height: 24);
      LayoutMode: Left;

      Group { FlexWeight: 1; }

      Label #PlayerHealthLabel {
        Anchor: (Height: 24);
        Style: (
          FontSize: 16,
          HorizontalAlignment: Center,
          RenderBold: true,
          TextColor: #ef4444
        );
        Text: "HP: 100 / 100";
      }

      Group { FlexWeight: 1; }
    }

    Group #UpgradeTracker {
      Anchor: (Left: 26, Bottom: 140, Width: 224, Height: 48);
      LayoutMode: Left;

      Group #UpgHp {
        Anchor: (Width: 48, Height: 48);
        Background: (TexturePath: "../Textures/golem_icon.png");
        Visible: false;

        Group #UpgHpOverlay {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Background: #0d1620(0.6);
        }

        Label #UpgHpLv {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Style: (
            FontSize: 14,
            HorizontalAlignment: Center,
            VerticalAlignment: Center,
            RenderBold: true,
            TextColor: #e7f1f4
          );
          Text: "Lv 0";
        }
      }

      Group { Anchor: (Width: 8); }

      Group #UpgAmmo {
        Anchor: (Width: 48, Height: 48);
        Background: (TexturePath: "../Textures/golem_icon.png");
        Visible: false;

        Group #UpgAmmoOverlay {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Background: #0d1620(0.6);
        }

        Label #UpgAmmoLv {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Style: (
            FontSize: 14,
            HorizontalAlignment: Center,
            VerticalAlignment: Center,
            RenderBold: true,
            TextColor: #e7f1f4
          );
          Text: "Lv 0";
        }
      }

      Group { Anchor: (Width: 8); }

      Group #UpgSpeed {
        Anchor: (Width: 48, Height: 48);
        Background: (TexturePath: "../Textures/golem_icon.png");
        Visible: false;

        Group #UpgSpeedOverlay {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Background: #0d1620(0.6);
        }

        Label #UpgSpeedLv {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Style: (
            FontSize: 14,
            HorizontalAlignment: Center,
            VerticalAlignment: Center,
            RenderBold: true,
            TextColor: #e7f1f4
          );
          Text: "Lv 0";
        }
      }

      Group { Anchor: (Width: 8); }

      Group #UpgLuck {
        Anchor: (Width: 48, Height: 48);
        Background: (TexturePath: "../Textures/golem_icon.png");
        Visible: false;

        Group #UpgLuckOverlay {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Background: #0d1620(0.6);
        }

        Label #UpgLuckLv {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Style: (
            FontSize: 14,
            HorizontalAlignment: Center,
            VerticalAlignment: Center,
            RenderBold: true,
            TextColor: #e7f1f4
          );
          Text: "Lv 0";
        }
      }
    }

    Group #WeaponXpHud {
      Anchor: (Left: 26, Bottom: 196, Width: 260, Height: 42);
      LayoutMode: Top;
      Background: #0d1620(0.88);
      OutlineColor: #ffffff(0.06);
      OutlineSize: 1;
      Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);
      Visible: false;

      Group #WxpTopRow {
        Anchor: (Left: 0, Right: 0, Height: 16);
        LayoutMode: Left;

        Label #WxpWeaponName {
          Anchor: (Height: 16);
          Style: (FontSize: 13, TextColor: #ffd44d, RenderBold: true, VerticalAlignment: Center);
          Text: "AK-47 Lv 0";
        }

        Group { FlexWeight: 1; }

        Label #WxpXpText {
          Anchor: (Height: 16);
          Style: (FontSize: 12, TextColor: #9eb7d4, VerticalAlignment: Center);
          Text: "0 / 25";
        }
      }

      ProgressBar #WxpBar {
        Anchor: (Left: 0, Right: 0, Top: 4, Height: 8);
        Value: 0;
        Bar: #ffd44d;
        Background: #ffd44d(0.12);
      }
    }

    Group #ScrapHudRoot {
      Anchor: (Left: 26, Bottom: 28, Width: 420, Height: 104);
      LayoutMode: Left;
      Background: #0d1620(0.92);
      OutlineColor: #ffffff(0.08);
      OutlineSize: 1;
      Padding: (Left: 18, Right: 18, Top: 10, Bottom: 10);

      Group #ScrapHudIcon {
        Anchor: (Width: 84, Height: 84);
        Background: (TexturePath: "../Textures/scrap.png");
      }

      Group { Anchor: (Width: 16); }

      Label #ScrapHudValue {
        Anchor: (Top: 0, Bottom: 0);
        Style: (
          FontSize: 62,
          TextColor: #f59e0b,
          RenderBold: true,
          VerticalAlignment: Center
        );
        Text: "0";
      }
    }
  }
}
