$C = "../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Left: 0, Right: 0, Bottom: 8, Height: 90);
  Background: #1a2530(0.95);

  Group #AccentBar {
    Anchor: (Width: 8, Top: 0, Bottom: 0);

    Group #AccentViolet {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #7c3aed;
      Visible: true;
    }

    Group #AccentRed {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #ef4444;
      Visible: false;
    }

    Group #AccentOrange {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #f59e0b;
      Visible: false;
    }

    Group #AccentGreen {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #10b981;
      Visible: false;
    }

    Group #AccentBlue {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #3b82f6;
      Visible: false;
    }

    Group #AccentGold {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #eab308;
      Visible: false;
    }
  }

  Group #ContentZone {
    FlexWeight: 1;
    Anchor: (Top: 0, Bottom: 0);
    Padding: (Left: 12, Top: 10, Bottom: 10);
    LayoutMode: Top;

    Label #MineName {
      Style: (
        FontSize: 16,
        RenderBold: true,
        TextColor: #f0f4f8
      );
      Text: "Mine";
    }

    Group #ProgressRow {
      Anchor: (Height: 14, Top: 6);
      LayoutMode: Left;

      Group #ProgressBar {
        Anchor: (Width: 300, Height: 8, Top: 3);
        Background: #000000(0.3);

        Group #Seg1 { Anchor: (Left: 0, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg2 { Anchor: (Left: 12, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg3 { Anchor: (Left: 24, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg4 { Anchor: (Left: 36, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg5 { Anchor: (Left: 48, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg6 { Anchor: (Left: 60, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg7 { Anchor: (Left: 72, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg8 { Anchor: (Left: 84, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg9 { Anchor: (Left: 96, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg10 { Anchor: (Left: 108, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg11 { Anchor: (Left: 120, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg12 { Anchor: (Left: 132, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg13 { Anchor: (Left: 144, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg14 { Anchor: (Left: 156, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg15 { Anchor: (Left: 168, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg16 { Anchor: (Left: 180, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg17 { Anchor: (Left: 192, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg18 { Anchor: (Left: 204, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg19 { Anchor: (Left: 216, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg20 { Anchor: (Left: 228, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg21 { Anchor: (Left: 240, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg22 { Anchor: (Left: 252, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg23 { Anchor: (Left: 264, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg24 { Anchor: (Left: 276, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg25 { Anchor: (Left: 288, Width: 10, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
      }
    }

    Label #MinerStatus {
      Anchor: (Top: 6);
      Style: (
        FontSize: 13,
        TextColor: #9fb0ba
      );
      Text: "";
    }
  }

  Group #ButtonZone {
    Anchor: (Width: 120, Top: 0, Bottom: 0);

    Group #ButtonBgViolet {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #7c3aed(0.85);
      Visible: false;
    }

    Group #ButtonBgRed {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #ef4444(0.85);
      Visible: false;
    }

    Group #ButtonBgOrange {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #f59e0b(0.85);
      Visible: false;
    }

    Group #ButtonBgGreen {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #10b981(0.85);
      Visible: false;
    }

    Group #ButtonBgBlue {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #3b82f6(0.85);
      Visible: false;
    }

    Group #ButtonBgGold {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #eab308(0.85);
      Visible: false;
    }

    Group #ButtonDisabledOverlay {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #000000(0.7);
      Visible: false;
    }

    Button #MinerBuyButton {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Padding: (Left: 8, Right: 8, Top: 4, Bottom: 6);
      Background: #00000000;
      Style: ButtonStyle(
        Default: (Background: #00000000),
        Hovered: (Background: #ffffff(0.15)),
        Pressed: (Background: #000000(0.15)),
        Sounds: $C.@ButtonSounds,
      );
      LayoutMode: Top;

      Group #StarContainer {
        Anchor: (Left: 0, Right: 0, Height: 18);
        LayoutMode: Left;

        Group {
          Anchor: (Width: 6);
        }

        Group #Star1 {
          Anchor: (Width: 16, Height: 16);
          Background: (TexturePath: "../Textures/star.png");
          Visible: false;
        }

        Group {
          Anchor: (Width: 4);
        }

        Group #Star2 {
          Anchor: (Width: 16, Height: 16);
          Background: (TexturePath: "../Textures/star.png");
          Visible: false;
        }

        Group {
          Anchor: (Width: 4);
        }

        Group #Star3 {
          Anchor: (Width: 16, Height: 16);
          Background: (TexturePath: "../Textures/star.png");
          Visible: false;
        }

        Group {
          Anchor: (Width: 4);
        }

        Group #Star4 {
          Anchor: (Width: 16, Height: 16);
          Background: (TexturePath: "../Textures/star.png");
          Visible: false;
        }

        Group {
          Anchor: (Width: 4);
        }

        Group #Star5 {
          Anchor: (Width: 16, Height: 16);
          Background: (TexturePath: "../Textures/star.png");
          Visible: false;
        }
      }

      Label #MinerLevel {
        Anchor: (Left: 0, Right: 0);
        Style: (
          FontSize: 16,
          RenderBold: true,
          TextColor: #7c3aed,
          HorizontalAlignment: Center
        );
        Text: "Lv.0";
      }

      Label #MinerActionStatus {
        Anchor: (Left: 0, Right: 0, Top: 1);
        Style: (
          FontSize: 14,
          TextColor: #9fb0ba,
          HorizontalAlignment: Center
        );
        Text: "No Miner";
      }

      Group #ActionRow {
        Anchor: (Left: 0, Right: 0, Top: 3);
        LayoutMode: Left;

        Group {
          FlexWeight: 1;
        }

        Label #ActionText {
          Style: (
            FontSize: 13,
            RenderBold: true,
            TextColor: #f0f4f8
          );
          Text: "Buy Miner";
        }

        Label #ActionPrice {
          Anchor: (Left: 2);
          Style: (
            FontSize: 13,
            TextColor: #f0f4f8
          );
          Text: "";
        }

        Group {
          FlexWeight: 1;
        }
      }
    }
  }

  // Locked overlay
  Group #LockedOverlay {
    Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
    Background: #0a1018(0.7);
    Visible: false;

    Label #LockedLabel {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Style: (FontSize: 13, TextColor: #4a5568, RenderBold: true, Alignment: Center, VerticalAlignment: Center);
      Text: "Mine Locked";
    }
  }
}
