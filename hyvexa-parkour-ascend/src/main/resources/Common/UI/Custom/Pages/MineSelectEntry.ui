$C = "../Common.ui";

Group {
  Anchor: (Left: 0, Right: 0, Top: 6, Height: 48);
  LayoutMode: Full;
  Background: #ffffff(0.03);
  OutlineColor: #ffffff(0.04);
  OutlineSize: 1;

  // Left accent bar (amber)
  Group {
    Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 4);
    Background: #f59e0b;
  }

  // Mine name
  Label #MineName {
    Anchor: (Left: 16, Top: 0, Bottom: 0, Width: 180);
    Style: (FontSize: 14, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
    Text: "Mine";
  }

  // === UNLOCKED STATE ===
  Group #UnlockedGroup {
    Anchor: (Right: 12, Top: 6, Width: 100, Height: 36);
    Visible: false;

    TextButton #TeleportButton {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Text: "Teleport";
      Style: TextButtonStyle(
        Default: (
          Background: #3d6b5a,
          LabelStyle: (FontSize: 13, TextColor: #e0fef0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
        ),
        Hovered: (
          Background: #4d8f7a,
          LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
        ),
        Pressed: (
          Background: #2d5a4a,
          LabelStyle: (FontSize: 13, TextColor: #e0fef0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
        ),
        Sounds: $C.@ButtonSounds,
      );
    }
  }

  // === LOCKED STATE ===
  Group #LockedGroup {
    Anchor: (Right: 12, Top: 6, Width: 200, Height: 36);
    LayoutMode: Right;
    Visible: false;

    // Cost label
    Label #CostLabel {
      Anchor: (Width: 90, Height: 36);
      Style: (FontSize: 13, TextColor: #f59e0b, HorizontalAlignment: End, VerticalAlignment: Center);
      Text: "0 crystals";
    }

    // Unlock button (can afford)
    Group #UnlockWrap {
      Anchor: (Left: 8, Width: 100, Height: 36);
      Visible: false;

      TextButton #UnlockButton {
        Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
        Text: "Unlock";
        Style: TextButtonStyle(
          Default: (
            Background: #7c5a1e,
            LabelStyle: (FontSize: 13, TextColor: #fde68a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
          ),
          Hovered: (
            Background: #a07825,
            LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
          ),
          Pressed: (
            Background: #5c4216,
            LabelStyle: (FontSize: 13, TextColor: #fde68a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
          ),
          Sounds: $C.@ButtonSounds,
        );
      }
    }

    // Disabled overlay (can't afford)
    Group #DisabledWrap {
      Anchor: (Left: 8, Width: 100, Height: 36);
      Visible: false;

      TextButton #DisabledButton {
        Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
        Text: "Unlock";
        Style: TextButtonStyle(
          Default: (
            Background: #ffffff(0.04),
            LabelStyle: (FontSize: 13, TextColor: #4b5563, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
          ),
          Hovered: (
            Background: #ffffff(0.06),
            LabelStyle: (FontSize: 13, TextColor: #6b7280, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
          ),
          Pressed: (
            Background: #ffffff(0.03),
            LabelStyle: (FontSize: 13, TextColor: #4b5563, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
          ),
          Sounds: $C.@ButtonSounds,
        );
      }
    }
  }
}
