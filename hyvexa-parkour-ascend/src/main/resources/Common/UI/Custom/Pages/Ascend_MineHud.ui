$C = "../Common.ui";

$C.@PageOverlay {
  Background: #000000(0.0);
  Group #MineHudLayer {
    Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);

    Group #CrystalHud {
      Anchor: (Left: 0, Right: 0, Top: 68, Height: 34);

      Group #CrystalBar {
        Anchor: (Width: 320, Height: 46);
        Background: #000000(0.60);
        LayoutMode: Top;

        Group #CrystalAccent {
          Anchor: (Left: 0, Right: 0, Height: 3);
          Background: #a78bfa;
        }

        Group #CrystalContent {
          FlexWeight: 1;
          Anchor: (Left: 0, Right: 0);
          LayoutMode: Left;

          Group { FlexWeight: 1; }

          Label #CrystalLabel {
            Anchor: (Top: 0, Bottom: 0);
            Style: (
              FontSize: 30,
              TextColor: #a78bfa,
              RenderBold: true,
              VerticalAlignment: Center
            );
            Text: "0";
          }

          Group { Anchor: (Width: 10); }

          Label #CrystalSuffix {
            Anchor: (Top: 0, Bottom: 0);
            Style: (
              FontSize: 22,
              TextColor: #9fb0ba,
              RenderBold: true,
              VerticalAlignment: Center
            );
            Text: "Crystals";
          }

          Group { FlexWeight: 1; }
        }
      }
    }

    Group #BagHud {
      Anchor: (Left: 20, Top: 130, Width: 260, Height: 280);
      LayoutMode: Left;

      Group #BagAccentBar {
        Anchor: (Width: 4, Top: 0, Bottom: 0);
        Background: #f59e0b;
      }

      Group #BagBox {
        FlexWeight: 1;
        Anchor: (Top: 0, Bottom: 0);
        Background: #0d1620(0.95);
        OutlineColor: #ffffff(0.06);
        OutlineSize: 1;
        LayoutMode: Top;
        Padding: (Left: 14, Right: 14, Top: 12, Bottom: 12);

        Label #BagTitle {
          Style: (FontSize: 12, TextColor: #f59e0b(0.7), RenderUppercase: true, LetterSpacing: 2, RenderBold: true);
          Text: "Inventory";
        }

        Label #MineNameLabel {
          Style: (FontSize: 14, TextColor: #f59e0b, RenderBold: true);
          Text: "";
          Visible: false;
        }

        Group #MineNameSep {
          Anchor: (Left: 0, Width: 30, Height: 1, Top: 4);
          Background: #f59e0b(0.3);
          Visible: false;
        }

        Group #BagSep {
          Anchor: (Left: 0, Width: 30, Height: 2, Top: 6);
          Background: #f59e0b;
        }

        Group #BagCountRow {
          Anchor: (Left: 0, Right: 0, Top: 10, Height: 30);
          LayoutMode: Left;

          Label #BagCountLabel {
            Anchor: (Top: 0, Bottom: 0);
            Style: (FontSize: 24, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
            Text: "0";
          }

          Label #BagSlash {
            Anchor: (Top: 0, Bottom: 0);
            Style: (FontSize: 24, TextColor: #9fb0ba, RenderBold: true, VerticalAlignment: Center);
            Text: "/";
          }

          Label #BagCapLabel {
            Anchor: (Top: 0, Bottom: 0);
            Style: (FontSize: 24, TextColor: #9fb0ba, RenderBold: true, VerticalAlignment: Center);
            Text: "50";
          }
        }

        Group #BlockList {
          Anchor: (Left: 0, Right: 0, Top: 8);
          LayoutMode: Top;

          Group #BlockEntry0 {
            Anchor: (Left: 0, Right: 0, Height: 22);
            LayoutMode: Left;
            Visible: false;

            Label #BlockName0 {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #cfd7dc, VerticalAlignment: Center);
              Text: "";
            }
            Group { FlexWeight: 1; }
            Label #BlockCount0 {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
              Text: "0";
            }
          }

          Group #BlockEntry1 {
            Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
            LayoutMode: Left;
            Visible: false;

            Label #BlockName1 {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #cfd7dc, VerticalAlignment: Center);
              Text: "";
            }
            Group { FlexWeight: 1; }
            Label #BlockCount1 {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
              Text: "0";
            }
          }

          Group #BlockEntry2 {
            Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
            LayoutMode: Left;
            Visible: false;

            Label #BlockName2 {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #cfd7dc, VerticalAlignment: Center);
              Text: "";
            }
            Group { FlexWeight: 1; }
            Label #BlockCount2 {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
              Text: "0";
            }
          }

          Group #BlockEntry3 {
            Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
            LayoutMode: Left;
            Visible: false;

            Label #BlockName3 {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #cfd7dc, VerticalAlignment: Center);
              Text: "";
            }
            Group { FlexWeight: 1; }
            Label #BlockCount3 {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
              Text: "0";
            }
          }

          Group #BlockEntry4 {
            Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
            LayoutMode: Left;
            Visible: false;

            Label #BlockName4 {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #cfd7dc, VerticalAlignment: Center);
              Text: "";
            }
            Group { FlexWeight: 1; }
            Label #BlockCount4 {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
              Text: "0";
            }
          }
        }

        Group #CooldownSection {
          Anchor: (Left: 0, Right: 0, Top: 10);
          LayoutMode: Top;
          Visible: false;

          Group #CooldownDivider {
            Anchor: (Left: 0, Right: 0, Height: 1);
            Background: #ffffff(0.06);
          }

          Group #CooldownRow {
            Anchor: (Left: 0, Right: 0, Top: 8, Height: 22);
            LayoutMode: Left;

            Label #CooldownLabel {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #ef4444, RenderBold: true, VerticalAlignment: Center);
              Text: "Regen";
            }
            Group { FlexWeight: 1; }
            Label #CooldownTimer {
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 16, TextColor: #ef4444, RenderBold: true, VerticalAlignment: Center);
              Text: "0s";
            }
          }
        }
      }
    }

    Group #ComboHud {
      Anchor: (Width: 180, Height: 36, Bottom: 170);
      Visible: false;
      LayoutMode: Left;

      Group #ComboAccent {
        Anchor: (Width: 3, Top: 0, Bottom: 0);
        Background: #3b82f6;
      }

      Group #ComboBox {
        FlexWeight: 1;
        Anchor: (Top: 0, Bottom: 0);
        Background: #0d1620(0.90);
        OutlineColor: #ffffff(0.06);
        OutlineSize: 1;
        LayoutMode: Top;

        Group #ComboRow {
          FlexWeight: 1;
          Anchor: (Left: 0, Right: 0);
          LayoutMode: Left;
          Padding: (Left: 8, Right: 8);

          Label #ComboLabel {
            Anchor: (Top: 0, Bottom: 0);
            Style: (FontSize: 12, TextColor: #3b82f6(0.7), RenderUppercase: true, LetterSpacing: 2, RenderBold: true, VerticalAlignment: Center);
            Text: "COMBO";
          }
          Group { FlexWeight: 1; }
          Label #ComboCount {
            Anchor: (Top: 0, Bottom: 0);
            Style: (FontSize: 22, TextColor: #3b82f6, RenderBold: true, VerticalAlignment: Center);
            Text: "0";
          }
        }

        ProgressBar #ComboTimer {
          Anchor: (Left: 0, Right: 0, Height: 3);
          Bar: #3b82f6;
          Background: #3b82f6(0.15);
          Value: 1;
        }
      }
    }

    Group #BlockHealthHud {
      Anchor: (Width: 220, Height: 44, Bottom: 120);
      Visible: false;
      LayoutMode: Top;

      Group #BlockHealthHeader {
        Anchor: (Left: 0, Right: 0, Height: 20);
        LayoutMode: Left;

        Label #BlockHealthName {
          Anchor: (Top: 0, Bottom: 0);
          Style: (FontSize: 16, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
          Text: "";
        }
        Group { FlexWeight: 1; }
        Label #BlockHealthText {
          Anchor: (Top: 0, Bottom: 0);
          Style: (FontSize: 14, TextColor: #9fb0ba, VerticalAlignment: Center);
          Text: "";
        }
      }

      ProgressBar #BlockHealthBar {
        Anchor: (Left: 0, Right: 0, Top: 4, Height: 14);
        Bar: #ef4444;
        Background: #ffffff(0.08);
        Value: 1;
      }
    }

    Group #MineToastContainer {
      Anchor: (Right: 0, Bottom: 0, Width: 300, Height: 400);

      Group #MineToast0 {
        Anchor: (Right: 20, Bottom: 170, Width: 280, Height: 44);
        Visible: false;
        LayoutMode: Left;

        Group #MineToast0Accent { Anchor: (Width: 4, Top: 0, Bottom: 0); Background: #a78bfa; }

        Group #MineToast0Content {
          FlexWeight: 1;
          Background: #0a1219(0.95);
          OutlineColor: #ffffff(0.1);
          OutlineSize: 1;
          LayoutMode: Top;

          Group #MineToast0Row {
            FlexWeight: 1;
            Anchor: (Left: 0, Right: 0);
            LayoutMode: Left;

            Group { Anchor: (Width: 6); }
            ItemIcon #MineToast0Icon { Anchor: (Width: 32, Top: 3, Bottom: 3); }
            Group { Anchor: (Width: 6); }
            Label #MineToast0Text {
              FlexWeight: 1;
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 15, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
              Text: "";
            }
          }

          ProgressBar #MineToast0Bar {
            Anchor: (Left: 0, Right: 0, Height: 3);
            Bar: #a78bfa;
            Background: #a78bfa(0.15);
            Value: 1;
          }
        }
      }

      Group #MineToast1 {
        Anchor: (Right: 20, Bottom: 218, Width: 280, Height: 44);
        Visible: false;
        LayoutMode: Left;

        Group #MineToast1Accent { Anchor: (Width: 4, Top: 0, Bottom: 0); Background: #a78bfa; }

        Group #MineToast1Content {
          FlexWeight: 1;
          Background: #0a1219(0.95);
          OutlineColor: #ffffff(0.1);
          OutlineSize: 1;
          LayoutMode: Top;

          Group #MineToast1Row {
            FlexWeight: 1;
            Anchor: (Left: 0, Right: 0);
            LayoutMode: Left;

            Group { Anchor: (Width: 6); }
            ItemIcon #MineToast1Icon { Anchor: (Width: 32, Top: 3, Bottom: 3); }
            Group { Anchor: (Width: 6); }
            Label #MineToast1Text {
              FlexWeight: 1;
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 15, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
              Text: "";
            }
          }

          ProgressBar #MineToast1Bar {
            Anchor: (Left: 0, Right: 0, Height: 3);
            Bar: #a78bfa;
            Background: #a78bfa(0.15);
            Value: 1;
          }
        }
      }

      Group #MineToast2 {
        Anchor: (Right: 20, Bottom: 266, Width: 280, Height: 44);
        Visible: false;
        LayoutMode: Left;

        Group #MineToast2Accent { Anchor: (Width: 4, Top: 0, Bottom: 0); Background: #a78bfa; }

        Group #MineToast2Content {
          FlexWeight: 1;
          Background: #0a1219(0.95);
          OutlineColor: #ffffff(0.1);
          OutlineSize: 1;
          LayoutMode: Top;

          Group #MineToast2Row {
            FlexWeight: 1;
            Anchor: (Left: 0, Right: 0);
            LayoutMode: Left;

            Group { Anchor: (Width: 6); }
            ItemIcon #MineToast2Icon { Anchor: (Width: 32, Top: 3, Bottom: 3); }
            Group { Anchor: (Width: 6); }
            Label #MineToast2Text {
              FlexWeight: 1;
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 15, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
              Text: "";
            }
          }

          ProgressBar #MineToast2Bar {
            Anchor: (Left: 0, Right: 0, Height: 3);
            Bar: #a78bfa;
            Background: #a78bfa(0.15);
            Value: 1;
          }
        }
      }

      Group #MineToast3 {
        Anchor: (Right: 20, Bottom: 314, Width: 280, Height: 44);
        Visible: false;
        LayoutMode: Left;

        Group #MineToast3Accent { Anchor: (Width: 4, Top: 0, Bottom: 0); Background: #a78bfa; }

        Group #MineToast3Content {
          FlexWeight: 1;
          Background: #0a1219(0.95);
          OutlineColor: #ffffff(0.1);
          OutlineSize: 1;
          LayoutMode: Top;

          Group #MineToast3Row {
            FlexWeight: 1;
            Anchor: (Left: 0, Right: 0);
            LayoutMode: Left;

            Group { Anchor: (Width: 6); }
            ItemIcon #MineToast3Icon { Anchor: (Width: 32, Top: 3, Bottom: 3); }
            Group { Anchor: (Width: 6); }
            Label #MineToast3Text {
              FlexWeight: 1;
              Anchor: (Top: 0, Bottom: 0);
              Style: (FontSize: 15, TextColor: #f0f4f8, RenderBold: true, VerticalAlignment: Center);
              Text: "";
            }
          }

          ProgressBar #MineToast3Bar {
            Anchor: (Left: 0, Right: 0, Height: 3);
            Bar: #a78bfa;
            Background: #a78bfa(0.15);
            Value: 1;
          }
        }
      }
    }

    Group #ScreenFade {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #000000;
      Visible: false;
      LayoutMode: Top;

      Group { FlexWeight: 1; }

      Group #FadeContent {
        Anchor: (Width: 300);
        LayoutMode: Top;

        Label #FadeText {
          Anchor: (Left: 0, Right: 0);
          Style: (FontSize: 18, TextColor: #9fb0ba, RenderBold: true, HorizontalAlignment: Center);
          Text: "";
        }

        Group { Anchor: (Height: 14); }

        ProgressBar #FadeBar {
          Anchor: (Left: 0, Right: 0, Height: 4);
          Bar: #a78bfa;
          Background: #ffffff(0.08);
          Value: 0;
        }
      }

      Group { FlexWeight: 1; }
    }
  }
}
