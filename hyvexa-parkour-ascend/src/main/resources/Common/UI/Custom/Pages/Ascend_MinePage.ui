$C = "../Common.ui";

$C.@PageOverlay {
  SceneBlur {}

  Group #MinePageWindow {
    Anchor: (Width: 500, Height: 560);
    LayoutMode: Top;
    Background: #0d1620(0.95);
    OutlineColor: #ffffff(0.06);
    OutlineSize: 1;

    // === HEADER ===
    Group #Header {
      Anchor: (Left: 0, Right: 0, Height: 52);
      LayoutMode: Full;
      Background: #0a1018;

      Group {
        Anchor: (Left: 0, Right: 0, Top: 0, Height: 2);
        Background: #f59e0b;
      }

      Label {
        Anchor: (Left: 20, Top: 16, Width: 200, Height: 24);
        Style: (FontSize: 18, TextColor: #f0f4f8, RenderBold: true);
        Text: "Mine";
      }

      Group {
        Anchor: (Right: 16, Top: 10, Width: 72, Height: 32);

        TextButton #CloseButton {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Text: "Close";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 13, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
      }
    }

    // === CONTENT ===
    Group #Content {
      Anchor: (Left: 0, Right: 0);
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Left: 16, Right: 16, Top: 6, Bottom: 12);

      // --- Tabs Row (4 tabs) ---
      Group #TabsRow {
        Anchor: (Left: 0, Right: 0, Height: 40);
        LayoutMode: Left;

        // Tab 1: Upgrade (active by default)
        Group #TabUpgradeWrap {
          Anchor: (Height: 36);
          FlexWeight: 1;
          OutlineColor: #ffffff(0.04);
          OutlineSize: 1;

          Group #TabUpgradeInactiveBg {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Background: #142029;
            Visible: false;
          }

          Group #TabUpgradeActiveBg {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Background: #2d3f50;
            Visible: true;
          }

          Group #TabUpgradeAccent {
            Anchor: (Left: 0, Right: 0, Top: 0, Height: 3);

            Group #TabUpgradeAccentInactive {
              Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
              Background: #142029;
              Visible: false;
            }

            Group #TabUpgradeAccentActive {
              Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
              Background: #f59e0b;
              Visible: true;
            }
          }

          Label #TabUpgradeLabel {
            Anchor: (Left: 0, Right: 0, Top: 6, Bottom: 0);
            Style: (FontSize: 13, RenderBold: true, TextColor: #f0f4f8, Alignment: Center, VerticalAlignment: Center);
            Text: "Upgrade";
          }

          TextButton #TabUpgrade {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Text: "";
            Style: TextButtonStyle(
              Default: (Background: #000000(0)),
              Hovered: (Background: #ffffff(0.05)),
              Pressed: (Background: #ffffff(0.1)),
              Sounds: $C.@ButtonSounds,
            );
          }
        }

        Group { Anchor: (Width: 4); }

        // Tab 2: Slots
        Group #TabSlotsWrap {
          Anchor: (Height: 36);
          FlexWeight: 1;
          OutlineColor: #ffffff(0.04);
          OutlineSize: 1;

          Group #TabSlotsInactiveBg {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Background: #142029;
            Visible: true;
          }

          Group #TabSlotsActiveBg {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Background: #2d3f50;
            Visible: false;
          }

          Group #TabSlotsAccent {
            Anchor: (Left: 0, Right: 0, Top: 0, Height: 3);

            Group #TabSlotsAccentInactive {
              Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
              Background: #142029;
              Visible: true;
            }

            Group #TabSlotsAccentActive {
              Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
              Background: #f59e0b;
              Visible: false;
            }
          }

          Label #TabSlotsLabel {
            Anchor: (Left: 0, Right: 0, Top: 6, Bottom: 0);
            Style: (FontSize: 13, RenderBold: true, TextColor: #9fb0ba, Alignment: Center, VerticalAlignment: Center);
            Text: "Slots";
          }

          TextButton #TabSlots {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Text: "";
            Style: TextButtonStyle(
              Default: (Background: #000000(0)),
              Hovered: (Background: #ffffff(0.05)),
              Pressed: (Background: #ffffff(0.1)),
              Sounds: $C.@ButtonSounds,
            );
          }
        }

        Group { Anchor: (Width: 4); }

        // Tab 3: Eggs
        Group #TabEggsWrap {
          Anchor: (Height: 36);
          FlexWeight: 1;
          OutlineColor: #ffffff(0.04);
          OutlineSize: 1;

          Group #TabEggsInactiveBg {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Background: #142029;
            Visible: true;
          }

          Group #TabEggsActiveBg {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Background: #2d3f50;
            Visible: false;
          }

          Group #TabEggsAccent {
            Anchor: (Left: 0, Right: 0, Top: 0, Height: 3);

            Group #TabEggsAccentInactive {
              Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
              Background: #142029;
              Visible: true;
            }

            Group #TabEggsAccentActive {
              Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
              Background: #f59e0b;
              Visible: false;
            }
          }

          Label #TabEggsLabel {
            Anchor: (Left: 0, Right: 0, Top: 6, Bottom: 0);
            Style: (FontSize: 13, RenderBold: true, TextColor: #9fb0ba, Alignment: Center, VerticalAlignment: Center);
            Text: "Eggs";
          }

          TextButton #TabEggs {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Text: "";
            Style: TextButtonStyle(
              Default: (Background: #000000(0)),
              Hovered: (Background: #ffffff(0.05)),
              Pressed: (Background: #ffffff(0.1)),
              Sounds: $C.@ButtonSounds,
            );
          }
        }

        Group { Anchor: (Width: 4); }

        // Tab 4: Collection
        Group #TabCollectionWrap {
          Anchor: (Height: 36);
          FlexWeight: 1;
          OutlineColor: #ffffff(0.04);
          OutlineSize: 1;

          Group #TabCollectionInactiveBg {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Background: #142029;
            Visible: true;
          }

          Group #TabCollectionActiveBg {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Background: #2d3f50;
            Visible: false;
          }

          Group #TabCollectionAccent {
            Anchor: (Left: 0, Right: 0, Top: 0, Height: 3);

            Group #TabCollectionAccentInactive {
              Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
              Background: #142029;
              Visible: true;
            }

            Group #TabCollectionAccentActive {
              Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
              Background: #f59e0b;
              Visible: false;
            }
          }

          Label #TabCollectionLabel {
            Anchor: (Left: 0, Right: 0, Top: 6, Bottom: 0);
            Style: (FontSize: 13, RenderBold: true, TextColor: #9fb0ba, Alignment: Center, VerticalAlignment: Center);
            Text: "Collection";
          }

          TextButton #TabCollection {
            Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
            Text: "";
            Style: TextButtonStyle(
              Default: (Background: #000000(0)),
              Hovered: (Background: #ffffff(0.05)),
              Pressed: (Background: #ffffff(0.1)),
              Sounds: $C.@ButtonSounds,
            );
          }
        }
      }

      // === UPGRADE TAB CONTENT (visible by default) ===
      Group #UpgradeContent {
        Anchor: (Left: 0, Right: 0, Top: 8);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #PickaxeRow {
          Anchor: (Left: 0, Right: 0);
          LayoutMode: Top;
        }

        Group { Anchor: (Height: 8); }

        Group #CardRow1 {
          Anchor: (Left: 0, Right: 0, Height: 115);
          LayoutMode: Left;

          Group #Slot0 { Anchor: (Width: 146, Height: 115); }
          Group { Anchor: (Width: 10); }
          Group #Slot1 { Anchor: (Width: 146, Height: 115); }
          Group { Anchor: (Width: 10); }
          Group #Slot2 { Anchor: (Width: 146, Height: 115); }
        }

        Group { Anchor: (Height: 10); }

        Group #CardRow2 {
          Anchor: (Left: 0, Right: 0, Height: 115);
          LayoutMode: Left;

          Group #Slot3 { Anchor: (Width: 146, Height: 115); }
          Group { Anchor: (Width: 10); }
          Group #Slot4 { Anchor: (Width: 146, Height: 115); }
          Group { Anchor: (Width: 10); }
          Group #Slot5 { Anchor: (Width: 146, Height: 115); }
        }

        Group { Anchor: (Height: 10); }

        Group #SlotBag {
          Anchor: (Left: 0, Right: 0);
          LayoutMode: Top;
        }

        Group { Anchor: (Height: 10); }

        Group #SlotConveyor {
          Anchor: (Left: 0, Right: 0);
          LayoutMode: Top;
        }
      }

      // === SLOTS TAB CONTENT (hidden by default) ===
      Group #SlotsContent {
        Anchor: (Left: 0, Right: 0, Top: 8);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Visible: false;

        Group #SlotEntries {
          LayoutMode: Top;
        }

        // Picker overlay (shown when assigning a miner to a slot)
        Group #PickerOverlay {
          Anchor: (Left: 0, Right: 0, Top: 8);
          LayoutMode: Top;
          Visible: false;

          Label #PickerTitle {
            Style: (FontSize: 14, RenderBold: true, TextColor: #f0f4f8);
            Text: "Select a miner:";
          }

          Group { Anchor: (Height: 6); }

          Group #PickerEntries {
            LayoutMode: Top;
          }
        }
      }

      // === EGGS TAB CONTENT (hidden by default) ===
      Group #EggsContent {
        Anchor: (Left: 0, Right: 0, Top: 8);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Visible: false;

        Group #EggEntries {
          LayoutMode: Top;
        }

        Label #NoEggsLabel {
          Anchor: (Top: 20);
          Style: (FontSize: 14, TextColor: #9fb0ba, Alignment: Center);
          Text: "No eggs yet. Break blocks to find eggs!";
        }
      }

      // === COLLECTION TAB CONTENT (hidden by default) ===
      Group #CollectionContent {
        Anchor: (Left: 0, Right: 0, Top: 8);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Visible: false;

        Group #CollectionEntries {
          LayoutMode: Top;
        }

        Label #NoMinersLabel {
          Anchor: (Top: 20);
          Style: (FontSize: 14, TextColor: #9fb0ba, Alignment: Center);
          Text: "No miners yet. Open eggs to collect miners!";
        }
      }

      // OP-only reset button (hidden by default)
      Group #ResetWrap {
        Anchor: (Left: 0, Right: 0, Height: 36, Top: 8);
        Visible: false;

        TextButton #ResetButton {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Text: "Reset All Upgrades (OP)";
          Style: TextButtonStyle(
            Default: (
              Background: #dc2626(0.6),
              LabelStyle: (FontSize: 13, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #dc2626(0.8),
              LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #dc2626(0.4),
              LabelStyle: (FontSize: 13, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
      }
    }
  }
}
