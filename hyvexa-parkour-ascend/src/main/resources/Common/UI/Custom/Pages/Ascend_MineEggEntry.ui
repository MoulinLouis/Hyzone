$C = "../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Left: 0, Right: 0, Bottom: 8, Height: 60);
  Background: #1a2530(0.95);

  Group #AccentBar {
    Anchor: (Width: 8, Top: 0, Bottom: 0);
    Background: #f59e0b;
  }

  Group #ContentZone {
    FlexWeight: 1;
    Anchor: (Top: 0, Bottom: 0);
    Padding: (Left: 12, Top: 8, Bottom: 8);
    LayoutMode: Top;

    Label #LayerName {
      Style: (FontSize: 15, RenderBold: true, TextColor: #f0f4f8);
      Text: "Layer";
    }

    Label #EggCount {
      Anchor: (Top: 4);
      Style: (FontSize: 13, TextColor: #9fb0ba);
      Text: "0 eggs";
    }
  }

  Group #ButtonZone {
    Anchor: (Width: 100, Top: 0, Bottom: 0);

    Group #OpenBg {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #f59e0b(0.85);
    }

    Group #ButtonDisabledOverlay {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #000000(0.7);
      Visible: false;
    }

    Button #OpenButton {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #00000000;
      Style: ButtonStyle(
        Default: (Background: #00000000),
        Hovered: (Background: #ffffff(0.15)),
        Pressed: (Background: #000000(0.15)),
        Sounds: $C.@ButtonSounds,
      );
      LayoutMode: Top;
      Padding: (Top: 14);

      Label #OpenText {
        Anchor: (Left: 0, Right: 0);
        Style: (FontSize: 15, RenderBold: true, TextColor: #f0f4f8, HorizontalAlignment: Center);
        Text: "Open";
      }
    }
  }
}
