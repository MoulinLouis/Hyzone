$C = "../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Left: 0, Right: 0, Bottom: 6, Height: 50);
  Background: #1a2530(0.95);

  Group #RarityBar {
    Anchor: (Width: 6, Top: 0, Bottom: 0);

    Group #AccentGray { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #aaaaaa; Visible: true; }
    Group #AccentGreen { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #10b981; Visible: false; }
    Group #AccentBlue { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #3b82f6; Visible: false; }
    Group #AccentPurple { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #a855f7; Visible: false; }
    Group #AccentOrange { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #f59e0b; Visible: false; }
  }

  Group #ContentZone {
    FlexWeight: 1;
    Anchor: (Top: 0, Bottom: 0);
    Padding: (Left: 10, Top: 6, Bottom: 6);
    LayoutMode: Top;

    Group #TopRow {
      Anchor: (Left: 0, Right: 0, Height: 18);
      LayoutMode: Left;

      Label #RarityLabel {
        Style: (FontSize: 13, RenderBold: true, TextColor: #aaaaaa);
        Text: "Common";
      }

      Label #LayerLabel {
        Anchor: (Left: 6);
        Style: (FontSize: 12, TextColor: #9fb0ba);
        Text: "";
      }
    }

    Label #SpeedLabel {
      Anchor: (Top: 2);
      Style: (FontSize: 12, TextColor: #9fb0ba);
      Text: "Speed Lv.0 | 6.0 b/m";
    }
  }

  Group #AssignedBadge {
    Anchor: (Right: 8, Width: 60, Top: 0, Bottom: 0);

    Label #AssignedText {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Style: (FontSize: 11, TextColor: #10b981, Alignment: Center, VerticalAlignment: Center);
      Text: "";
      Visible: false;
    }
  }
}
