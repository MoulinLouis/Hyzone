$C = "../Common.ui";

Group {
  Anchor: (Left: 0, Right: 0, Top: 4, Height: 36);
  LayoutMode: Full;
  Background: #ffffff(0.03);
  OutlineColor: #ffffff(0.04);
  OutlineSize: 1;

  ItemIcon #BlockIcon {
    Anchor: (Left: 8, Top: 4, Width: 28, Height: 28);
    ShowItemTooltip: true;
  }

  Label #BlockName {
    Anchor: (Left: 42, Top: 0, Bottom: 0, Width: 180);
    Style: (FontSize: 13, TextColor: #f0f4f8, VerticalAlignment: Center);
    Text: "Block";
  }

  Label #BlockProb {
    Anchor: (Left: 228, Top: 0, Bottom: 0, Width: 60);
    Style: (FontSize: 13, TextColor: #9fb0ba, VerticalAlignment: Center);
    Text: "0.0";
  }

  TextButton #HpDownBtn {
    Anchor: (Left: 296, Top: 8, Width: 20, Height: 20);
    Text: "-";
    Style: TextButtonStyle(
      Default: (
        Background: #475569(0.5),
        LabelStyle: (FontSize: 12, TextColor: #9fb0ba, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
      ),
      Hovered: (
        Background: #475569(0.8),
        LabelStyle: (FontSize: 12, TextColor: #f0f4f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
      ),
      Pressed: (
        Background: #475569(0.3),
        LabelStyle: (FontSize: 12, TextColor: #9fb0ba, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
      ),
      Sounds: $C.@ButtonSounds,
    );
  }

  Label #BlockHp {
    Anchor: (Left: 318, Top: 0, Bottom: 0, Width: 40);
    Style: (FontSize: 13, TextColor: #ef4444, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
    Text: "1 HP";
  }

  TextButton #HpUpBtn {
    Anchor: (Left: 360, Top: 8, Width: 20, Height: 20);
    Text: "+";
    Style: TextButtonStyle(
      Default: (
        Background: #475569(0.5),
        LabelStyle: (FontSize: 12, TextColor: #9fb0ba, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
      ),
      Hovered: (
        Background: #475569(0.8),
        LabelStyle: (FontSize: 12, TextColor: #f0f4f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
      ),
      Pressed: (
        Background: #475569(0.3),
        LabelStyle: (FontSize: 12, TextColor: #9fb0ba, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
      ),
      Sounds: $C.@ButtonSounds,
    );
  }

  TextButton #RemoveBtn {
    Anchor: (Right: 8, Top: 6, Width: 24, Height: 24);
    Text: "X";
    Style: TextButtonStyle(
      Default: (
        Background: #dc2626(0.4),
        LabelStyle: (FontSize: 12, TextColor: #fca5a5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
      ),
      Hovered: (
        Background: #dc2626(0.7),
        LabelStyle: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
      ),
      Pressed: (
        Background: #dc2626(0.3),
        LabelStyle: (FontSize: 12, TextColor: #fca5a5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
      ),
      Sounds: $C.@ButtonSounds,
    );
  }
}
