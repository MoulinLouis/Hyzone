$C = "../Common.ui";

$C.@PageOverlay {
  $C.@Container {
    Anchor: (Width: 720, Height: 620);

    #Title {
      Group {
        TextButton #BackButton {
          Anchor: (Left: 12, Top: 4, Width: 64, Height: 24);
          Padding: (Left: 8, Top: 2);
          Text: "Back";
          Style: TextButtonStyle(
            Default: (
              Background: #000000(0.13),
              LabelStyle: (FontSize: 14, TextColor: #93844c, RenderBold: true)
            ),
            Hovered: (
              Background: #000000(0.22),
              LabelStyle: (FontSize: 14, TextColor: #93844c, RenderBold: true)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
        $C.@Title {
          @Text = "Choose Block";
        }
      }
    }

    #Content {
      Padding: (Left: 12, Right: 12, Top: 6, Bottom: 12);

      Group #BlockGrid {
        Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #BlockEntries {
          LayoutMode: Top;
        }
      }
    }
  }
}
