$C = "../Common.ui";

$C.@PageOverlay {
  SceneBlur {}

  Group #PickaxeAdminWindow {
    Anchor: (Width: 560, Height: 580);
    LayoutMode: Top;
    Background: #0d1620(0.95);
    OutlineColor: #ffffff(0.06);
    OutlineSize: 1;

    // Header
    Group #Header {
      Anchor: (Left: 0, Right: 0, Height: 52);
      LayoutMode: Full;
      Background: #0a1018;

      Group {
        Anchor: (Left: 0, Right: 0, Top: 0, Height: 2);
        Background: #f59e0b;
      }

      Label {
        Anchor: (Left: 20, Top: 16, Width: 200, Height: 24);
        Style: (FontSize: 18, TextColor: #f0f4f8, RenderBold: true);
        Text: "Pickaxe Config";
      }

      Group {
        Anchor: (Right: 16, Top: 10, Width: 72, Height: 32);

        TextButton #CloseButton {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Text: "Close";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 13, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
      }
    }

    // Content — two columns
    Group #Content {
      Anchor: (Left: 0, Right: 0);
      FlexWeight: 1;
      LayoutMode: Left;

      // === Left column: Tier info + Recipe + Costs ===
      Group #LeftCol {
        Anchor: (Top: 0, Bottom: 0, Width: 280);
        LayoutMode: Top;
        Padding: (Left: 16, Right: 8, Top: 12, Bottom: 12);

        // Tier navigation
        Group {
          Anchor: (Left: 0, Right: 0, Height: 36);
          LayoutMode: Left;

          TextButton #TierPrev {
            Anchor: (Width: 32, Height: 32);
            Text: "<";
            Style: TextButtonStyle(
              Default: (
                Background: #ffffff(0.06),
                LabelStyle: (FontSize: 16, TextColor: #f0f4f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
              ),
              Hovered: (
                Background: #ffffff(0.12),
                LabelStyle: (FontSize: 16, TextColor: #f0f4f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
              ),
              Sounds: $C.@ButtonSounds,
            );
          }

          Group {
            FlexWeight: 1;
            Anchor: (Top: 0, Bottom: 0);
            LayoutMode: Top;
            Padding: (Left: 8, Top: 2);

            Label #TierTitle {
              Style: (FontSize: 15, TextColor: #f59e0b, RenderBold: true);
              Text: "Wood Pickaxe (Tier 0)";
            }

            Label #TierDamage {
              Anchor: (Top: 2);
              Style: (FontSize: 11, TextColor: #9fb0ba);
              Text: "Base Damage: 1";
            }
          }

          TextButton #TierNext {
            Anchor: (Width: 32, Height: 32);
            Text: ">";
            Style: TextButtonStyle(
              Default: (
                Background: #ffffff(0.06),
                LabelStyle: (FontSize: 16, TextColor: #f0f4f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
              ),
              Hovered: (
                Background: #ffffff(0.12),
                LabelStyle: (FontSize: 16, TextColor: #f0f4f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
              ),
              Sounds: $C.@ButtonSounds,
            );
          }
        }

        // Separator
        Group {
          Anchor: (Left: 0, Right: 0, Top: 8, Height: 1);
          Background: #ffffff(0.08);
        }

        // --- Tier Recipe Section ---
        Label {
          Anchor: (Top: 8);
          Style: (FontSize: 13, TextColor: #f0f4f8, RenderBold: true);
          Text: "Tier Recipe";
        }

        Label #RecipeEmpty {
          Anchor: (Top: 4);
          Style: (FontSize: 11, TextColor: #6b7c8a);
          Text: "No recipe configured";
        }

        Group #RecipeList {
          Anchor: (Left: 0, Right: 0, Top: 4, Height: 72);
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
        }

        // Selected block + amount + add
        Group {
          Anchor: (Left: 0, Right: 0, Top: 6, Height: 26);
          LayoutMode: Left;

          Label #SelectedBlockText {
            Anchor: (Top: 4);
            FlexWeight: 1;
            Style: (FontSize: 11, TextColor: #9fb0ba);
            Text: "No block selected";
          }

          Group {
            Anchor: (Left: 4, Width: 44);
            LayoutMode: Top;

            $C.@TextField #AmountField {
              Anchor: (Height: 24);
              Style: (FontSize: 11, TextColor: #f0f4f8);
            }
          }

          TextButton #AddRecipeBtn {
            Anchor: (Left: 4, Width: 50, Height: 24);
            Text: "Add";
            Style: TextButtonStyle(
              Default: (
                Background: #10b981(0.8),
                LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
              ),
              Hovered: (
                Background: #10b981,
                LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
              ),
              Sounds: $C.@ButtonSounds,
            );
          }
        }

        // Separator
        Group {
          Anchor: (Left: 0, Right: 0, Top: 8, Height: 1);
          Background: #ffffff(0.08);
        }

        // --- Enhancement Costs Section ---
        Label {
          Anchor: (Top: 8);
          Style: (FontSize: 13, TextColor: #f0f4f8, RenderBold: true);
          Text: "Enhancement Costs";
        }

        // Cost input row
        Group {
          Anchor: (Left: 0, Right: 0, Top: 4, Height: 24);
          LayoutMode: Left;

          Label {
            Anchor: (Width: 70, Top: 4);
            Style: (FontSize: 11, TextColor: #9fb0ba);
            Text: "Crystal cost:";
          }

          Group {
            Anchor: (Left: 4, Width: 80);
            LayoutMode: Top;

            $C.@TextField #CostField {
              Anchor: (Height: 22);
              Style: (FontSize: 11, TextColor: #f0f4f8);
            }
          }
        }

        // Level rows
        Group {
          Anchor: (Left: 0, Right: 0, Top: 4);
          LayoutMode: Top;

          // Level 1
          Group {
            Anchor: (Left: 0, Right: 0, Height: 22);
            LayoutMode: Left;

            Label #CostLabel1 {
              Anchor: (Width: 140, Top: 3);
              Style: (FontSize: 11, TextColor: #9fb0ba);
              Text: "Lv 1: Free";
            }

            TextButton #SetCost1 {
              Anchor: (Left: 4, Width: 40, Height: 20);
              Text: "Set";
              Style: TextButtonStyle(
                Default: (
                  Background: #ffffff(0.06),
                  LabelStyle: (FontSize: 10, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
                ),
                Hovered: (
                  Background: #ffffff(0.1),
                  LabelStyle: (FontSize: 10, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
                ),
                Sounds: $C.@ButtonSounds,
              );
            }
          }

          // Level 2
          Group {
            Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
            LayoutMode: Left;

            Label #CostLabel2 {
              Anchor: (Width: 140, Top: 3);
              Style: (FontSize: 11, TextColor: #9fb0ba);
              Text: "Lv 2: Free";
            }

            TextButton #SetCost2 {
              Anchor: (Left: 4, Width: 40, Height: 20);
              Text: "Set";
              Style: TextButtonStyle(
                Default: (
                  Background: #ffffff(0.06),
                  LabelStyle: (FontSize: 10, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
                ),
                Hovered: (
                  Background: #ffffff(0.1),
                  LabelStyle: (FontSize: 10, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
                ),
                Sounds: $C.@ButtonSounds,
              );
            }
          }

          // Level 3
          Group {
            Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
            LayoutMode: Left;

            Label #CostLabel3 {
              Anchor: (Width: 140, Top: 3);
              Style: (FontSize: 11, TextColor: #9fb0ba);
              Text: "Lv 3: Free";
            }

            TextButton #SetCost3 {
              Anchor: (Left: 4, Width: 40, Height: 20);
              Text: "Set";
              Style: TextButtonStyle(
                Default: (
                  Background: #ffffff(0.06),
                  LabelStyle: (FontSize: 10, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
                ),
                Hovered: (
                  Background: #ffffff(0.1),
                  LabelStyle: (FontSize: 10, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
                ),
                Sounds: $C.@ButtonSounds,
              );
            }
          }

          // Level 4
          Group {
            Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
            LayoutMode: Left;

            Label #CostLabel4 {
              Anchor: (Width: 140, Top: 3);
              Style: (FontSize: 11, TextColor: #9fb0ba);
              Text: "Lv 4: Free";
            }

            TextButton #SetCost4 {
              Anchor: (Left: 4, Width: 40, Height: 20);
              Text: "Set";
              Style: TextButtonStyle(
                Default: (
                  Background: #ffffff(0.06),
                  LabelStyle: (FontSize: 10, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
                ),
                Hovered: (
                  Background: #ffffff(0.1),
                  LabelStyle: (FontSize: 10, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
                ),
                Sounds: $C.@ButtonSounds,
              );
            }
          }

          // Level 5
          Group {
            Anchor: (Left: 0, Right: 0, Top: 2, Height: 22);
            LayoutMode: Left;

            Label #CostLabel5 {
              Anchor: (Width: 140, Top: 3);
              Style: (FontSize: 11, TextColor: #9fb0ba);
              Text: "Lv 5: Free";
            }

            TextButton #SetCost5 {
              Anchor: (Left: 4, Width: 40, Height: 20);
              Text: "Set";
              Style: TextButtonStyle(
                Default: (
                  Background: #ffffff(0.06),
                  LabelStyle: (FontSize: 10, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
                ),
                Hovered: (
                  Background: #ffffff(0.1),
                  LabelStyle: (FontSize: 10, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
                ),
                Sounds: $C.@ButtonSounds,
              );
            }
          }
        }
      }

      // === Right column: Block picker ===
      Group #RightCol {
        Anchor: (Top: 0, Bottom: 0);
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Left: 8, Right: 16, Top: 12, Bottom: 12);

        Label {
          Style: (FontSize: 13, TextColor: #f0f4f8, RenderBold: true);
          Text: "Choose Block";
        }

        Group #BlockEntries {
          Anchor: (Left: 0, Right: 0, Top: 6);
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
        }
      }
    }
  }
}
