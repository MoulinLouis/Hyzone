$C = "../Common.ui";

$C.@PageOverlay {
  $C.@Container {
    Anchor: (Width: 650, Height: 680);

    #Title {
      Group {
        TextButton #CloseButton {
          Anchor: (Left: 12, Top: 4, Width: 64, Height: 24);
          Padding: (Left: 8, Top: 2);
          Text: "Close";
          Style: TextButtonStyle(
            Default: (
              Background: #000000(0.13),
              LabelStyle: (FontSize: 14, TextColor: #93844c, RenderBold: true)
            ),
            Hovered: (
              Background: #000000(0.22),
              LabelStyle: (FontSize: 14, TextColor: #93844c, RenderBold: true)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
        $C.@Title {
          @Text = "Mine Gate Admin";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 18, Right: 18, Top: 12, Bottom: 12);

      Label {
        Style: (FontSize: 16, TextColor: #93844c, RenderBold: true);
        Text: "Entry Gate (into mine)";
      }

      Label #EntryBoundsText {
        Anchor: (Top: 6);
        Style: (FontSize: 13, TextColor: #9fb0ba);
        Text: "AABB: Not set";
      }

      Label #EntryDestText {
        Anchor: (Top: 4);
        Style: (FontSize: 13, TextColor: #9fb0ba);
        Text: "Dest: Not set";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Top: 6, Height: 32);

        $C.@TextButton #EntryPos1Button {
          Anchor: (Width: 140, Height: 32);
          Text: "Set Pos1";
        }

        $C.@TextButton #EntryPos2Button {
          Anchor: (Left: 8, Width: 140, Height: 32);
          Text: "Set Pos2";
        }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Top: 6, Height: 32);

        $C.@TextButton #SaveEntryButton {
          Anchor: (Width: 140, Height: 32);
          Text: "Save AABB";
        }

        $C.@TextButton #SetEntryDestButton {
          Anchor: (Left: 8, Width: 140, Height: 32);
          Text: "Set Dest";
        }
      }

      Label #EntryStatusText {
        Anchor: (Top: 6);
        Style: (FontSize: 13, TextColor: #9fb0ba, RenderBold: true);
        Text: "Entry: NOT CONFIGURED";
      }

      Label {
        Anchor: (Top: 16);
        Style: (FontSize: 16, TextColor: #93844c, RenderBold: true);
        Text: "Exit Gate (out of mine)";
      }

      Label #ExitBoundsText {
        Anchor: (Top: 6);
        Style: (FontSize: 13, TextColor: #9fb0ba);
        Text: "AABB: Not set";
      }

      Label #ExitDestText {
        Anchor: (Top: 4);
        Style: (FontSize: 13, TextColor: #9fb0ba);
        Text: "Dest: Not set";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Top: 6, Height: 32);

        $C.@TextButton #ExitPos1Button {
          Anchor: (Width: 140, Height: 32);
          Text: "Set Pos1";
        }

        $C.@TextButton #ExitPos2Button {
          Anchor: (Left: 8, Width: 140, Height: 32);
          Text: "Set Pos2";
        }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Top: 6, Height: 32);

        $C.@TextButton #SaveExitButton {
          Anchor: (Width: 140, Height: 32);
          Text: "Save AABB";
        }

        $C.@TextButton #SetExitDestButton {
          Anchor: (Left: 8, Width: 140, Height: 32);
          Text: "Set Dest";
        }
      }

      Label #ExitStatusText {
        Anchor: (Top: 6);
        Style: (FontSize: 13, TextColor: #9fb0ba, RenderBold: true);
        Text: "Exit: NOT CONFIGURED";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Top: 16, Height: 32);

        $C.@TextButton #BackButton {
          Anchor: (Width: 140, Height: 32);
          Text: "Back";
        }
      }
    }
  }
}
