$C = "../Common.ui";

$C.@PageOverlay {
  SceneBlur {}

  Group #MineSellWindow {
    Anchor: (Width: 480, Height: 560);
    LayoutMode: Top;
    Background: #0d1620(0.95);
    OutlineColor: #ffffff(0.06);
    OutlineSize: 1;

    Group #Header {
      Anchor: (Left: 0, Right: 0, Height: 52);
      LayoutMode: Full;
      Background: #0a1018;

      Group {
        Anchor: (Left: 0, Right: 0, Top: 0, Height: 2);
        Background: #f59e0b;
      }

      Label {
        Anchor: (Left: 20, Top: 16, Width: 200, Height: 24);
        Style: (FontSize: 18, TextColor: #f0f4f8, RenderBold: true);
        Text: "Sell Blocks";
      }

      Group {
        Anchor: (Right: 16, Top: 10, Width: 72, Height: 32);

        TextButton #CloseButton {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Text: "Close";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 13, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
      }
    }

    Group #Content {
      Anchor: (Left: 0, Right: 0);
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Left: 16, Right: 16, Top: 12, Bottom: 12);

      // Capacity
      Group #CardCapacity {
        Anchor: (Left: 0, Right: 0, Height: 36);
        LayoutMode: Full;
        Background: #ffffff(0.03);
        OutlineColor: #ffffff(0.04);
        OutlineSize: 1;

        Group {
          Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 4);
          Background: #f59e0b;
        }

        Label {
          Anchor: (Left: 16, Top: 0, Bottom: 0, Width: 100);
          Style: (FontSize: 13, TextColor: #9fb0ba, VerticalAlignment: Center);
          Text: "Bag";
        }

        Label #CapacityValue {
          Anchor: (Left: 120, Right: 16, Top: 0, Bottom: 0);
          Style: (FontSize: 15, TextColor: #f59e0b, RenderBold: true, VerticalAlignment: Center);
          Text: "0 / 50 blocks";
        }
      }

      // Crystals
      Group #CardCrystals {
        Anchor: (Left: 0, Right: 0, Height: 36, Top: 6);
        LayoutMode: Full;
        Background: #ffffff(0.03);
        OutlineColor: #ffffff(0.04);
        OutlineSize: 1;

        Group {
          Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 4);
          Background: #a78bfa;
        }

        Label {
          Anchor: (Left: 16, Top: 0, Bottom: 0, Width: 100);
          Style: (FontSize: 13, TextColor: #9fb0ba, VerticalAlignment: Center);
          Text: "Crystals";
        }

        Label #CrystalsValue {
          Anchor: (Left: 120, Right: 16, Top: 0, Bottom: 0);
          Style: (FontSize: 15, TextColor: #a78bfa, RenderBold: true, VerticalAlignment: Center);
          Text: "0";
        }
      }

      // Total value
      Group #CardTotalValue {
        Anchor: (Left: 0, Right: 0, Height: 36, Top: 6);
        LayoutMode: Full;
        Background: #ffffff(0.03);
        OutlineColor: #ffffff(0.04);
        OutlineSize: 1;

        Group {
          Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 4);
          Background: #34d399;
        }

        Label {
          Anchor: (Left: 16, Top: 0, Bottom: 0, Width: 100);
          Style: (FontSize: 13, TextColor: #9fb0ba, VerticalAlignment: Center);
          Text: "Total Value";
        }

        Label #TotalValue {
          Anchor: (Left: 120, Right: 16, Top: 0, Bottom: 0);
          Style: (FontSize: 15, TextColor: #34d399, RenderBold: true, VerticalAlignment: Center);
          Text: "0 crystals";
        }
      }

      // Empty state
      Label #EmptyLabel {
        Anchor: (Left: 0, Right: 0, Top: 16);
        Style: (FontSize: 14, TextColor: #4b5563, HorizontalAlignment: Center);
        Text: "Bag is empty";
      }

      // Block list
      Group #ScrollArea {
        Anchor: (Left: 0, Right: 0, Top: 10);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #SellItems {
          LayoutMode: Top;
          Padding: (Top: 4);
        }
      }

      // Sell All button
      Group #SellAllWrap {
        Anchor: (Left: 0, Right: 0, Height: 44, Top: 10);
        LayoutMode: Full;

        TextButton #SellAllButton {
          Anchor: (Left: 60, Right: 60, Top: 0, Bottom: 0);
          Text: "Sell All";
          Style: TextButtonStyle(
            Default: (
              Background: #f59e0b,
              LabelStyle: (FontSize: 16, TextColor: #0d1620, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #fbbf24,
              LabelStyle: (FontSize: 16, TextColor: #0d1620, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #d97706,
              LabelStyle: (FontSize: 16, TextColor: #0d1620, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
      }
    }
  }
}
