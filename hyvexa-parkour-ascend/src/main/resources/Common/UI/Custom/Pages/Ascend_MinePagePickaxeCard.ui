$C = "../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Left: 0, Right: 0, Bottom: 12, Height: 100);
  Background: #1a2530(0.95);
  OutlineColor: #f59e0b(0.3);
  OutlineSize: 1;

  Group #AccentBar {
    Anchor: (Width: 8, Top: 0, Bottom: 0);
    Background: #f59e0b;
  }

  Group #ContentZone {
    FlexWeight: 1;
    Anchor: (Top: 0, Bottom: 0);
    Padding: (Left: 12, Top: 10, Bottom: 10);
    LayoutMode: Top;

    Label #TierName {
      Style: (
        FontSize: 16,
        RenderBold: true,
        TextColor: #f59e0b
      );
      Text: "Wood Pickaxe";
    }

    Label #SpeedText {
      Anchor: (Top: 4);
      Style: (
        FontSize: 13,
        TextColor: #9fb0ba
      );
      Text: "Speed: 1.0x";
    }

    Label #RequirementText {
      Anchor: (Top: 2);
      Style: (
        FontSize: 12,
        TextColor: #9fb0ba
      );
      Text: "";
    }
  }

  Group #ButtonZone {
    Anchor: (Width: 120, Top: 0, Bottom: 0);

    Group #ButtonBgGold {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #f59e0b(0.85);
    }

    Group #ButtonDisabledOverlay {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #000000(0.7);
      Visible: false;
    }

    Button #PickaxeBuyButton {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Padding: (Left: 8, Right: 8, Top: 14, Bottom: 6);
      Background: #00000000;
      Style: ButtonStyle(
        Default: (Background: #00000000),
        Hovered: (Background: #ffffff(0.15)),
        Pressed: (Background: #000000(0.15)),
        Sounds: $C.@ButtonSounds,
      );
      LayoutMode: Top;

      Label #TierLabel {
        Anchor: (Left: 0, Right: 0);
        Style: (
          FontSize: 15,
          RenderBold: true,
          TextColor: #ffffff,
          HorizontalAlignment: Center
        );
        Text: "Tier 0";
      }

      Label #ActionText {
        Anchor: (Left: 0, Right: 0, Top: 4);
        Style: (
          FontSize: 13,
          RenderBold: true,
          TextColor: #f0f4f8,
          HorizontalAlignment: Center
        );
        Text: "";
      }

      Label #ActionPrice {
        Anchor: (Left: 0, Right: 0, Top: 1);
        Style: (
          FontSize: 13,
          TextColor: #f0f4f8,
          HorizontalAlignment: Center
        );
        Text: "";
      }
    }
  }
}
