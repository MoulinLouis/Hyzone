$C = "../Common.ui";

Group {
  Anchor: (Left: 0, Right: 0, Height: 64);
  LayoutMode: Full;
  Background: #ffffff(0.03);

  Group {
    Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 4);
    Background: #f59e0b;
  }

  Label #UpgradeName {
    Anchor: (Left: 16, Top: 8, Width: 200, Height: 20);
    Style: (FontSize: 14, TextColor: #f0f4f8, RenderBold: true);
    Text: "Upgrade";
  }

  Label #LevelText {
    Anchor: (Left: 16, Top: 30, Width: 120, Height: 18);
    Style: (FontSize: 12, TextColor: #9fb0ba);
    Text: "Lv 0 / 100";
  }

  Label #EffectText {
    Anchor: (Left: 140, Top: 30, Width: 140, Height: 18);
    Style: (FontSize: 12, TextColor: #f59e0b);
    Text: "Speed: 1.0x";
  }

  Label #CostText {
    Anchor: (Right: 110, Top: 8, Width: 120, Height: 18);
    Style: (FontSize: 12, TextColor: #a78bfa, HorizontalAlignment: End);
    Text: "Cost: 10";
  }

  Group #BuyWrap {
    Anchor: (Right: 8, Top: 10, Width: 90, Height: 44);

    TextButton #BuyButton {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Text: "Buy";
      Style: TextButtonStyle(
        Default: (
          Background: #3d6b5a,
          LabelStyle: (FontSize: 13, TextColor: #e0fef0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
        ),
        Hovered: (
          Background: #4d8f7a,
          LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
        ),
        Pressed: (
          Background: #2d5a4a,
          LabelStyle: (FontSize: 13, TextColor: #e0fef0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
        ),
        Sounds: $C.@ButtonSounds,
      );
    }
  }

  Label #MaxedLabel {
    Anchor: (Right: 20, Top: 10, Width: 90, Height: 44);
    Style: (FontSize: 14, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
    Text: "MAXED";
    Visible: false;
  }
}
