$C = "../Common.ui";

$C.@PageOverlay {
  SceneBlur {}

  Group #MineAdminWindow {
    Anchor: (Width: 620, Height: 620);
    LayoutMode: Top;
    Background: #0d1620(0.95);
    OutlineColor: #ffffff(0.06);
    OutlineSize: 1;

    // Header
    Group #Header {
      Anchor: (Left: 0, Right: 0, Height: 52);
      LayoutMode: Full;
      Background: #0a1018;

      Group {
        Anchor: (Left: 0, Right: 0, Top: 0, Height: 2);
        Background: #f59e0b;
      }

      Label {
        Anchor: (Left: 20, Top: 16, Width: 200, Height: 24);
        Style: (FontSize: 18, TextColor: #f0f4f8, RenderBold: true);
        Text: "Mine Admin";
      }

      Group {
        Anchor: (Right: 16, Top: 10, Width: 72, Height: 32);

        TextButton #CloseButton {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Text: "Close";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 13, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
      }
    }

    // Content
    Group #Content {
      Anchor: (Left: 0, Right: 0);
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Left: 16, Right: 16, Top: 12, Bottom: 12);

      // Selected mine info card
      Group #SelectedCard {
        Anchor: (Left: 0, Right: 0, Height: 42);
        LayoutMode: Full;
        Background: #ffffff(0.03);
        OutlineColor: #ffffff(0.04);
        OutlineSize: 1;

        Group {
          Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 4);
          Background: #f59e0b;
        }

        Label #SelectedMineText {
          Anchor: (Left: 16, Top: 6, Right: 16, Height: 16);
          Style: (FontSize: 13, TextColor: #f0f4f8, RenderBold: true);
          Text: "No mine selected";
        }

        Label #MineInfoText {
          Anchor: (Left: 16, Top: 22, Right: 16, Height: 14);
          Style: (FontSize: 11, TextColor: #6b7c8a);
          Text: "";
        }
      }

      // Empty state
      Label #EmptyLabel {
        Anchor: (Left: 0, Right: 0, Top: 16);
        Style: (FontSize: 14, TextColor: #4b5563, HorizontalAlignment: Center);
        Text: "No mines configured";
      }

      // Mine list
      Group #MineList {
        Anchor: (Left: 0, Right: 0, Top: 8);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #MineCards {
          LayoutMode: Top;
        }
      }

      // Form section (progressive disclosure)
      Group #FormSection {
        Anchor: (Left: 0, Right: 0, Top: 10);
        LayoutMode: Top;
        Visible: false;

        // Separator
        Group {
          Anchor: (Left: 0, Right: 0, Height: 1);
          Background: #ffffff(0.06);
        }

        Group {
          Anchor: (Left: 0, Right: 0, Top: 8);
          LayoutMode: Left;

          Group {
            FlexWeight: 1;
            LayoutMode: Top;

            Label {
              Text: "Mine ID";
              Style: (FontSize: 11, TextColor: #6b7c8a);
            }

            $C.@TextField #MineIdField {
              Anchor: (Height: 26, Top: 2);
              Style: (FontSize: 13, TextColor: #ffffff(0.85));
            }
          }

          Group {
            Anchor: (Left: 8);
            FlexWeight: 1;
            LayoutMode: Top;

            Label {
              Text: "Mine Name";
              Style: (FontSize: 11, TextColor: #6b7c8a);
            }

            $C.@TextField #MineNameField {
              Anchor: (Height: 26, Top: 2);
              Style: (FontSize: 13, TextColor: #ffffff(0.85));
            }
          }
        }

        Group {
          Anchor: (Left: 0, Right: 0, Top: 6);
          LayoutMode: Left;

          Group {
            FlexWeight: 1;
            LayoutMode: Top;

            Label {
              Text: "Display Order";
              Style: (FontSize: 11, TextColor: #6b7c8a);
            }

            $C.@TextField #MineOrderField {
              Anchor: (Height: 26, Top: 2);
              Style: (FontSize: 13, TextColor: #ffffff(0.85));
            }
          }

          Group {
            Anchor: (Left: 8);
            FlexWeight: 1;
            LayoutMode: Top;

            Label {
              Text: "Unlock Cost";
              Style: (FontSize: 11, TextColor: #6b7c8a);
            }

            $C.@TextField #MineCostField {
              Anchor: (Height: 26, Top: 2);
              Style: (FontSize: 13, TextColor: #ffffff(0.85));
            }
          }
        }
      }

      // Footer buttons
      Group #Footer {
        Anchor: (Left: 0, Right: 0, Top: 10, Height: 36);
        LayoutMode: Left;

        TextButton #CreateButton {
          Anchor: (Width: 90, Height: 34);
          Text: "Create";
          Style: TextButtonStyle(
            Default: (
              Background: #f59e0b,
              LabelStyle: (FontSize: 13, TextColor: #1a1a2a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #fbbf24,
              LabelStyle: (FontSize: 13, TextColor: #1a1a2a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #d97706,
              LabelStyle: (FontSize: 13, TextColor: #1a1a2a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #SetNameButton {
          Anchor: (Left: 6, Width: 80, Height: 34);
          Text: "Set Name";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 13, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #SetOrderButton {
          Anchor: (Left: 6, Width: 80, Height: 34);
          Text: "Set Order";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 13, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #SetCostButton {
          Anchor: (Left: 6, Width: 80, Height: 34);
          Text: "Set Cost";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 13, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #SetSpawnButton {
          Anchor: (Left: 6, Width: 86, Height: 34);
          Text: "Set Spawn";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 13, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #DeleteButton {
          Anchor: (Left: 6, Width: 72, Height: 34);
          Text: "Delete";
          Style: TextButtonStyle(
            Default: (
              Background: #dc2626(0.6),
              LabelStyle: (FontSize: 13, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #dc2626(0.8),
              LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #dc2626(0.4),
              LabelStyle: (FontSize: 13, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
      }

      // Sub-page buttons (row 1)
      Group #SubPages {
        Anchor: (Left: 0, Right: 0, Top: 6, Height: 34);
        LayoutMode: Left;

        TextButton #ZonesButton {
          Anchor: (Width: 66, Height: 32);
          Text: "Zones";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 12, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #GateButton {
          Anchor: (Left: 4, Width: 56, Height: 32);
          Text: "Gate";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 12, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #BlockConfigButton {
          Anchor: (Left: 4, Width: 80, Height: 32);
          Text: "Blocks";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 12, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #SetMinerPosButton {
          Anchor: (Left: 4, Width: 80, Height: 32);
          Text: "Miner Pos";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 12, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        Group { FlexWeight: 1; }

        TextButton #BackButton {
          Anchor: (Width: 60, Height: 32);
          Text: "Back";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 12, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
      }

      // Conveyor waypoint controls (row 2)
      Group #WaypointRow {
        Anchor: (Left: 0, Right: 0, Top: 4, Height: 34);
        LayoutMode: Left;

        TextButton #SlotPrevButton {
          Anchor: (Width: 40, Height: 32);
          Text: "S-";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 12, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        Label #SlotLabel {
          Anchor: (Left: 4, Width: 52, Height: 32);
          Style: (FontSize: 12, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Slot: 0";
        }

        TextButton #SlotNextButton {
          Anchor: (Left: 4, Width: 40, Height: 32);
          Text: "S+";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 12, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 12, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #AddSlotWpButton {
          Anchor: (Left: 8, Width: 72, Height: 32);
          Text: "+Slot WP";
          Style: TextButtonStyle(
            Default: (
              Background: #3b82f6(0.4),
              LabelStyle: (FontSize: 12, TextColor: #93c5fd, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #3b82f6(0.6),
              LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #3b82f6(0.3),
              LabelStyle: (FontSize: 12, TextColor: #93c5fd, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #AddMainWpButton {
          Anchor: (Left: 4, Width: 80, Height: 32);
          Text: "+Main WP";
          Style: TextButtonStyle(
            Default: (
              Background: #f59e0b(0.4),
              LabelStyle: (FontSize: 12, TextColor: #fcd34d, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #f59e0b(0.6),
              LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #f59e0b(0.3),
              LabelStyle: (FontSize: 12, TextColor: #fcd34d, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #ClearSlotWpButton {
          Anchor: (Left: 4, Width: 68, Height: 32);
          Text: "CLR Slot";
          Style: TextButtonStyle(
            Default: (
              Background: #dc2626(0.3),
              LabelStyle: (FontSize: 12, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #dc2626(0.5),
              LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #dc2626(0.2),
              LabelStyle: (FontSize: 12, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        TextButton #ClearMainWpButton {
          Anchor: (Left: 4, Width: 72, Height: 32);
          Text: "CLR Main";
          Style: TextButtonStyle(
            Default: (
              Background: #dc2626(0.3),
              LabelStyle: (FontSize: 12, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #dc2626(0.5),
              LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #dc2626(0.2),
              LabelStyle: (FontSize: 12, TextColor: #fca5a5, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
      }
    }
  }
}
