$C = "../Common.ui";

$C.@PageOverlay {
  $C.@Container {
    Anchor: (Width: 920, Height: 780);

    #Title {
      Group {
        TextButton #CloseButton {
          Anchor: (Left: 12, Top: 4, Width: 64, Height: 24);
          Padding: (Left: 8, Top: 2);
          Text: "Close";
          Style: TextButtonStyle(
            Default: (
              Background: #000000(0.13),
              LabelStyle: (FontSize: 14, TextColor: #93844c, RenderBold: true)
            ),
            Hovered: (
              Background: #000000(0.22),
              LabelStyle: (FontSize: 14, TextColor: #93844c, RenderBold: true)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
        $C.@Title {
          @Text = "Mine Admin";
        }
      }
    }

    #Content {
      LayoutMode: Left;
      Padding: (Left: 12, Right: 12, Top: 6, Bottom: 12);

      Group #FormColumn {
        Anchor: (Width: 300);
        LayoutMode: Top;

        Label {
          Style: (FontSize: 16, TextColor: #93844c, RenderBold: true);
          Text: "Create / Edit Mine";
        }

        Label {
          Text: "Mine Id";
          Style: (FontSize: 13, TextColor: #cfd7dc);
          Anchor: (Top: 4);
        }

        $C.@TextField #MineIdField {
          Anchor: (Height: 28);
          Style: (FontSize: 14, TextColor: #ffffff(0.85));
        }

        Label {
          Text: "Mine Name";
          Style: (FontSize: 13, TextColor: #cfd7dc);
          Anchor: (Top: 4);
        }

        $C.@TextField #MineNameField {
          Anchor: (Height: 28);
          Style: (FontSize: 14, TextColor: #ffffff(0.85));
        }

        Label {
          Text: "Display Order";
          Style: (FontSize: 13, TextColor: #cfd7dc);
          Anchor: (Top: 4);
        }

        $C.@TextField #MineOrderField {
          Anchor: (Height: 28);
          Style: (FontSize: 14, TextColor: #ffffff(0.85));
        }

        Label {
          Text: "Unlock Cost (mantissa,exponent)";
          Style: (FontSize: 13, TextColor: #cfd7dc);
          Anchor: (Top: 4);
        }

        $C.@TextField #MineCostField {
          Anchor: (Height: 28);
          Style: (FontSize: 14, TextColor: #ffffff(0.85));
        }

        Label #SelectedMineText {
          Anchor: (Top: 8);
          Style: (FontSize: 13, TextColor: #9fb0ba, RenderBold: true);
          Text: "Selected: (none)";
        }

        Label #MineInfoText {
          Anchor: (Top: 2);
          Style: (FontSize: 12, TextColor: #7a9aa8);
          Text: "";
        }

        Group {
          LayoutMode: Left;
          Anchor: (Top: 8, Height: 32);

          $C.@TextButton #CreateButton {
            Anchor: (Width: 140, Height: 30);
            Text: "Create";
          }

          $C.@TextButton #SetNameButton {
            Anchor: (Left: 8, Width: 140, Height: 30);
            Text: "Set Name";
          }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Top: 6, Height: 32);

          $C.@TextButton #SetOrderButton {
            Anchor: (Width: 140, Height: 30);
            Text: "Set Order";
          }

          $C.@TextButton #SetCostButton {
            Anchor: (Left: 8, Width: 140, Height: 30);
            Text: "Set Cost";
          }
        }

        Label {
          Text: "Position (at your location)";
          Style: (FontSize: 14, TextColor: #93844c, RenderBold: true);
          Anchor: (Top: 12);
        }

        Group {
          LayoutMode: Left;
          Anchor: (Top: 6, Height: 32);

          $C.@TextButton #SetSpawnButton {
            Anchor: (Width: 140, Height: 30);
            Text: "Set Spawn";
          }

          $C.@TextButton #DeleteButton {
            Anchor: (Left: 8, Width: 140, Height: 30);
            Text: "Delete";
          }
        }

        Label {
          Text: "Sub-pages";
          Style: (FontSize: 14, TextColor: #93844c, RenderBold: true);
          Anchor: (Top: 12);
        }

        Group {
          LayoutMode: Left;
          Anchor: (Top: 6, Height: 32);

          $C.@TextButton #ZonesButton {
            Anchor: (Width: 140, Height: 30);
            Text: "Zones";
          }

          $C.@TextButton #GateButton {
            Anchor: (Left: 8, Width: 140, Height: 30);
            Text: "Gate";
          }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Top: 10, Height: 32);

          $C.@TextButton #BackButton {
            Anchor: (Width: 140, Height: 32);
            Text: "Back";
          }
        }
      }

      Group #ListColumn {
        Anchor: (Left: 16, Width: 560);
        LayoutMode: Top;

        Label {
          Style: (FontSize: 16, TextColor: #93844c, RenderBold: true);
          Text: "Mines";
        }

        Group #MineList {
          Anchor: (Top: 6, Width: 540, Height: 660);
          LayoutMode: TopScrolling;
          Padding: (Left: 6, Right: 6);
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          Group #MineCards {
            LayoutMode: Top;
          }
        }
      }
    }
  }
}
