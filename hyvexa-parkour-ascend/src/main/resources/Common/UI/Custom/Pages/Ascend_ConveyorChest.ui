$C = "../Common.ui";

$C.@PageOverlay {
  SceneBlur {}

  Group #ConveyorChestWindow {
    Anchor: (Width: 480, Height: 540);
    LayoutMode: Top;
    Background: #0d1620(0.95);
    OutlineColor: #ffffff(0.06);
    OutlineSize: 1;

    // === HEADER ===
    Group #Header {
      Anchor: (Left: 0, Right: 0, Height: 52);
      LayoutMode: Full;
      Background: #0a1018;

      Group {
        Anchor: (Left: 0, Right: 0, Top: 0, Height: 2);
        Background: #f59e0b;
      }

      Label {
        Anchor: (Left: 20, Top: 16, Width: 240, Height: 24);
        Style: (FontSize: 18, TextColor: #f0f4f8, RenderBold: true);
        Text: "Conveyor Storage";
      }

      Group {
        Anchor: (Right: 16, Top: 10, Width: 72, Height: 32);

        TextButton #CloseButton {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Text: "Close";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 13, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
      }
    }

    // === CONTENT ===
    Group #Content {
      Anchor: (Left: 0, Right: 0);
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Left: 16, Right: 16, Top: 12, Bottom: 12);

      // Bag capacity card
      Group #CardCapacity {
        Anchor: (Left: 0, Right: 0, Height: 36);
        LayoutMode: Full;
        Background: #ffffff(0.03);
        OutlineColor: #ffffff(0.04);
        OutlineSize: 1;

        Group {
          Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 4);
          Background: #f59e0b;
        }

        Label {
          Anchor: (Left: 16, Top: 0, Bottom: 0, Width: 100);
          Style: (FontSize: 13, TextColor: #9fb0ba, VerticalAlignment: Center);
          Text: "Bag Space";
        }

        Label #CapacityValue {
          Anchor: (Left: 120, Right: 16, Top: 0, Bottom: 0);
          Style: (FontSize: 15, TextColor: #f59e0b, RenderBold: true, VerticalAlignment: Center);
          Text: "0 / 50 free";
        }
      }

      // Buffer count card
      Group #CardBuffer {
        Anchor: (Left: 0, Right: 0, Height: 36, Top: 6);
        LayoutMode: Full;
        Background: #ffffff(0.03);
        OutlineColor: #ffffff(0.04);
        OutlineSize: 1;

        Group {
          Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 4);
          Background: #60a5fa;
        }

        Label {
          Anchor: (Left: 16, Top: 0, Bottom: 0, Width: 100);
          Style: (FontSize: 13, TextColor: #9fb0ba, VerticalAlignment: Center);
          Text: "In Chest";
        }

        Label #BufferValue {
          Anchor: (Left: 120, Right: 16, Top: 0, Bottom: 0);
          Style: (FontSize: 15, TextColor: #60a5fa, RenderBold: true, VerticalAlignment: Center);
          Text: "0 blocks";
        }
      }

      // Empty state
      Label #EmptyLabel {
        Anchor: (Left: 0, Right: 0, Top: 16);
        Style: (FontSize: 14, TextColor: #4b5563, HorizontalAlignment: Center);
        Text: "The chest is empty";
      }

      // Block cards
      Group #ScrollArea {
        Anchor: (Left: 0, Right: 0, Top: 10);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #BlockEntries {
          LayoutMode: Top;
        }
      }

      // Empty (OP only)
      Group #EmptyOpWrap {
        Anchor: (Left: 0, Right: 0, Top: 6, Height: 34);
        LayoutMode: Left;
        Visible: false;

        Group { FlexWeight: 1; }

        TextButton #EmptyOpButton {
          Anchor: (Width: 140, Height: 32);
          Text: "EMPTY (OP)";
          Style: TextButtonStyle(
            Default: (
              Background: #7f1d1d,
              LabelStyle: (FontSize: 13, TextColor: #fca5a5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #991b1b,
              LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #450a0a,
              LabelStyle: (FontSize: 13, TextColor: #fca5a5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        Group { FlexWeight: 1; }
      }

      // Collect All button
      Group #CollectAllWrap {
        Anchor: (Left: 0, Right: 0, Top: 10, Height: 40);
        LayoutMode: Left;

        Group { FlexWeight: 1; }

        TextButton #CollectAllButton {
          Anchor: (Width: 160, Height: 38);
          Text: "Collect All";
          Style: TextButtonStyle(
            Default: (
              Background: #3d6b5a,
              LabelStyle: (FontSize: 14, TextColor: #e0fef0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #4d8f7a,
              LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #2d5a4a,
              LabelStyle: (FontSize: 14, TextColor: #e0fef0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }

        Group { FlexWeight: 1; }
      }
    }
  }
}
