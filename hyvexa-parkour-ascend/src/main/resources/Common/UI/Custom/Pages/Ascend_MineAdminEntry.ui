$C = "../Common.ui";

Button {
  Anchor: (Left: 0, Right: 0, Top: 6, Height: 56);
  LayoutMode: Full;
  Background: #1a2530(0.95);
  OutlineColor: #ffffff(0.06);
  OutlineSize: 1;
  Padding: (Left: 16, Right: 12, Top: 8);
  Style: ButtonStyle(
    Default: (Background: #1a2530(0.95)),
    Hovered: (Background: #2d3f50),
    Pressed: (Background: #1a2530),
    Sounds: $C.@ButtonSounds,
  );

  Group #AccentBar {
    Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 4);
    Background: #f59e0b;
    Visible: false;
  }

  Label #MineName {
    Anchor: (Left: 4, Top: 0, Right: 0, Height: 20);
    Style: (FontSize: 14, TextColor: #f0f4f8, RenderBold: true);
    Text: "Mine";
  }

  Label #MineStatus {
    Anchor: (Left: 4, Top: 22, Right: 0, Height: 16);
    Style: (FontSize: 11, TextColor: #6b7c8a);
    Text: "Status";
  }
}
