$C = "../Common.ui";

Group {
  Anchor: (Width: 146, Height: 115);
  Background: #1a2530;
  OutlineColor: #ffffff(0.06);
  OutlineSize: 1;

  // === Accent bar (top 3px) ===
  Group #CardAccent {
    Anchor: (Left: 0, Right: 0, Top: 0, Height: 3);

    Group #AccentBlue { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #3b82f6; Visible: false; }
    Group #AccentGold { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #f59e0b; Visible: false; }
    Group #AccentRed { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #ef4444; Visible: false; }
    Group #AccentOrange { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #f97316; Visible: false; }
    Group #AccentViolet { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
    Group #AccentGreen { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: #10b981; Visible: false; }
  }

  // === Card icon (centered, placeholder — replace per-upgrade later) ===
  Group #CardIcon {
    Anchor: (Left: 55, Width: 36, Height: 36, Top: 28);
    Background: (TexturePath: "../Textures/golem_icon.png");
  }

  // === Card name ===
  Label #CardName {
    Anchor: (Left: 6, Right: 6, Top: 7);
    Style: (FontSize: 15, RenderBold: true, TextColor: #f0f4f8, HorizontalAlignment: Center);
    Text: "";
  }

  // === Effect description ===
  Label #CardEffect {
    Anchor: (Left: 4, Right: 4, Top: 68);
    Style: (FontSize: 13, TextColor: #9fb0ba, HorizontalAlignment: Center);
    Text: "";
  }

  // === Bottom row: Level + Cost ===
  Group #BottomRow {
    Anchor: (Left: 6, Right: 6, Bottom: 4, Height: 18);
    LayoutMode: Left;

    Label #CardLevel {
      Style: (FontSize: 14, RenderBold: true, TextColor: #cfd7dc);
      Text: "";
    }

    Group { FlexWeight: 1; }

    Label #CardCost {
      Style: (FontSize: 13, TextColor: #9fb0ba);
      Text: "";
    }
  }

  // === Disabled overlay ===
  Group #CardDisabled {
    Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
    Background: #000000(0.6);
    Visible: false;
  }

  // === Buy button (full card, on top for interaction) ===
  TextButton #CardBuyBtn {
    Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
    Text: "";
    Style: TextButtonStyle(
      Default: (Background: #000000(0)),
      Hovered: (Background: #ffffff(0.08)),
      Pressed: (Background: #ffffff(0.15)),
      Sounds: $C.@ButtonSounds,
    );
  }
}
