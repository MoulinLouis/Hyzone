$C = "../Common.ui";

$C.@PageOverlay {
  SceneBlur {}

  Group #MinerDefWindow {
    Anchor: (Width: 780, Height: 520);
    LayoutMode: Top;
    Background: #0d1620(0.95);
    OutlineColor: #ffffff(0.06);
    OutlineSize: 1;

    // Header
    Group #Header {
      Anchor: (Left: 0, Right: 0, Height: 52);
      LayoutMode: Full;
      Background: #0a1018;

      Group {
        Anchor: (Left: 0, Right: 0, Top: 0, Height: 2);
        Background: #f59e0b;
      }

      Label #HeaderTitle {
        Anchor: (Left: 20, Top: 16, Width: 400, Height: 24);
        Style: (FontSize: 18, TextColor: #f0f4f8, RenderBold: true);
        Text: "Miner Definitions";
      }

      Group {
        Anchor: (Right: 16, Top: 10, Width: 72, Height: 32);

        TextButton #BackButton {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Text: "Back";
          Style: TextButtonStyle(
            Default: (
              Background: #ffffff(0.06),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Hovered: (
              Background: #ffffff(0.1),
              LabelStyle: (FontSize: 13, TextColor: #f0f4f8, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Pressed: (
              Background: #ffffff(0.04),
              LabelStyle: (FontSize: 13, TextColor: #cfd7dc, HorizontalAlignment: Center, VerticalAlignment: Center)
            ),
            Sounds: $C.@ButtonSounds,
          );
        }
      }
    }

    // Content: left panel (layer list) + right panel (rarity cards)
    Group #Content {
      Anchor: (Left: 0, Right: 0);
      FlexWeight: 1;
      LayoutMode: Left;
      Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);

      // Left panel — layer list
      Group #LeftPanel {
        Anchor: (Width: 170, Top: 0, Bottom: 0);
        LayoutMode: Top;

        Label {
          Anchor: (Left: 0, Right: 0, Height: 18);
          Style: (FontSize: 12, TextColor: #6b7c8a, RenderBold: true);
          Text: "Layers";
        }

        Group #LayerScroll {
          Anchor: (Left: 0, Right: 0, Top: 4);
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          Group #LayerList {
            LayoutMode: Top;
          }
        }
      }

      // Separator
      Group {
        Anchor: (Left: 8, Width: 1, Top: 0, Bottom: 0);
        Background: #ffffff(0.06);
      }

      // Right panel — rarity cards
      Group #RightPanel {
        Anchor: (Left: 8, Top: 0, Bottom: 0);
        FlexWeight: 1;
        LayoutMode: Top;

        Label #SelectedLayerLabel {
          Anchor: (Left: 0, Right: 0, Height: 18);
          Style: (FontSize: 12, TextColor: #6b7c8a, RenderBold: true);
          Text: "Select a layer";
        }

        Group #RarityCards {
          Anchor: (Left: 0, Right: 0, Top: 6);
          FlexWeight: 1;
          LayoutMode: Left;
        }
      }
    }
  }
}
