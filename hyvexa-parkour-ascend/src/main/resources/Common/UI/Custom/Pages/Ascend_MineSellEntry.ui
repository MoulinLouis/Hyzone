Group {
  Anchor: (Left: 0, Right: 0, Height: 28);
  LayoutMode: Left;
  Padding: (Left: 4, Right: 4, Top: 4);

  Label #BlockName {
    Anchor: (Width: 160, Height: 22);
    Style: (FontSize: 13, TextColor: #cfd7dc);
    Text: "Block";
  }

  Label #Quantity {
    Anchor: (Left: 4, Width: 60, Height: 22);
    Style: (FontSize: 13, TextColor: #f59e0b, RenderBold: true);
    Text: "x0";
  }

  Label #Value {
    Anchor: (Left: 4, Width: 120, Height: 22);
    Style: (FontSize: 13, TextColor: #9fb0ba);
    Text: "0 crystals";
  }
}
