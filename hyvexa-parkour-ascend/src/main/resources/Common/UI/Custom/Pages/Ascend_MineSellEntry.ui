$C = "../Common.ui";

Group {
  Anchor: (Left: 0, Right: 0, Height: 48);
  LayoutMode: Full;
  Background: #ffffff(0.03);
  OutlineColor: #ffffff(0.04);
  OutlineSize: 1;
  Padding: (Left: 8, Right: 8);

  // Icon container
  Group #IconWrap {
    Anchor: (Left: 8, Top: 6, Width: 36, Height: 36);
    LayoutMode: Full;
    Background: #ffffff(0.04);
    OutlineColor: #ffffff(0.06);
    OutlineSize: 1;

    Group #IconStone { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: (TexturePath: "../Textures/Rock_Stone.png"); Visible: false; }
    Group #IconBlue { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: (TexturePath: "../Textures/Rock_Crystal_Blue.png"); Visible: false; }
    Group #IconGreen { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: (TexturePath: "../Textures/Rock_Crystal_Green.png"); Visible: false; }
    Group #IconPink { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: (TexturePath: "../Textures/Rock_Crystal_Pink.png"); Visible: false; }
    Group #IconRed { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: (TexturePath: "../Textures/Rock_Crystal_Red.png"); Visible: false; }
    Group #IconWhite { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: (TexturePath: "../Textures/Rock_Crystal_White.png"); Visible: false; }
    Group #IconYellow { Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0); Background: (TexturePath: "../Textures/Rock_Crystal_Yellow.png"); Visible: false; }
  }

  // Block name
  Label #BlockName {
    Anchor: (Left: 54, Top: 0, Bottom: 0, Width: 140);
    Style: (FontSize: 13, TextColor: #f0f4f8, VerticalAlignment: Center);
    Text: "Block";
  }

  // Quantity
  Label #Quantity {
    Anchor: (Left: 200, Top: 0, Bottom: 0, Width: 60);
    Style: (FontSize: 13, TextColor: #f59e0b, RenderBold: true, VerticalAlignment: Center);
    Text: "x0";
  }

  // Value
  Label #Value {
    Anchor: (Right: 12, Top: 0, Bottom: 0, Width: 120);
    Style: (FontSize: 13, TextColor: #34d399, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: Right);
    Text: "0 crystals";
  }
}
