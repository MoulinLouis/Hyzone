$C = "../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Left: 0, Right: 0, Bottom: 8, Height: 90);
  Background: #1a2530(0.95);

  Group #AccentBar {
    Anchor: (Width: 8, Top: 0, Bottom: 0);

    Group #AccentViolet {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #7c3aed;
      Visible: true;
    }

    Group #AccentGreen {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #10b981;
      Visible: false;
    }

    Group #AccentRed {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #ef4444;
      Visible: false;
    }
  }

  Group #ContentZone {
    FlexWeight: 1;
    Anchor: (Top: 0, Bottom: 0);
    Padding: (Left: 12, Top: 10, Bottom: 10);
    LayoutMode: Top;

    Label #UpgradeName {
      Style: (
        FontSize: 16,
        RenderBold: true,
        TextColor: #f0f4f8
      );
      Text: "Upgrade";
    }

    Group #ProgressRow {
      Anchor: (Height: 14, Top: 6);
      LayoutMode: Left;

      Group #ProgressBar {
        Anchor: (Width: 300, Height: 8, Top: 3);
        Background: #000000(0.3);

        Group #Seg1 { Anchor: (Left: 0, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg2 { Anchor: (Left: 15, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg3 { Anchor: (Left: 30, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg4 { Anchor: (Left: 45, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg5 { Anchor: (Left: 60, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg6 { Anchor: (Left: 75, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg7 { Anchor: (Left: 90, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg8 { Anchor: (Left: 105, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg9 { Anchor: (Left: 120, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg10 { Anchor: (Left: 135, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg11 { Anchor: (Left: 150, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg12 { Anchor: (Left: 165, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg13 { Anchor: (Left: 180, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg14 { Anchor: (Left: 195, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg15 { Anchor: (Left: 210, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg16 { Anchor: (Left: 225, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg17 { Anchor: (Left: 240, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg18 { Anchor: (Left: 255, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg19 { Anchor: (Left: 270, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
        Group #Seg20 { Anchor: (Left: 285, Width: 13, Top: 0, Bottom: 0); Background: #7c3aed; Visible: false; }
      }
    }

    Label #EffectText {
      Anchor: (Top: 6);
      Style: (
        FontSize: 13,
        TextColor: #9fb0ba
      );
      Text: "";
    }
  }

  Group #ButtonZone {
    Anchor: (Width: 120, Top: 0, Bottom: 0);

    Group #ButtonBgViolet {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #7c3aed(0.85);
      Visible: false;
    }

    Group #ButtonBgGreen {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #10b981(0.85);
      Visible: false;
    }

    Group #ButtonBgRed {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #ef4444(0.85);
      Visible: false;
    }

    Group #ButtonDisabledOverlay {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: #000000(0.7);
      Visible: false;
    }

    Button #UpgradeBuyButton {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Padding: (Left: 8, Right: 8, Top: 12, Bottom: 6);
      Background: #00000000;
      Style: ButtonStyle(
        Default: (Background: #00000000),
        Hovered: (Background: #ffffff(0.15)),
        Pressed: (Background: #000000(0.15)),
        Sounds: $C.@ButtonSounds,
      );
      LayoutMode: Top;

      Label #LevelText {
        Anchor: (Left: 0, Right: 0);
        Style: (
          FontSize: 16,
          RenderBold: true,
          TextColor: #ffffff,
          HorizontalAlignment: Center
        );
        Text: "Lv.0";
      }

      Label #UpgradeStatus {
        Anchor: (Left: 0, Right: 0, Top: 1);
        Style: (
          FontSize: 14,
          TextColor: #ffffff,
          HorizontalAlignment: Center
        );
        Text: "";
      }

      Group #ActionRow {
        Anchor: (Left: 0, Right: 0, Top: 3);
        LayoutMode: Left;

        Group {
          FlexWeight: 1;
        }

        Label #ActionText {
          Style: (
            FontSize: 13,
            RenderBold: true,
            TextColor: #f0f4f8
          );
          Text: "Upgrade";
        }

        Label #ActionPrice {
          Anchor: (Left: 2);
          Style: (
            FontSize: 13,
            TextColor: #f0f4f8
          );
          Text: "";
        }

        Group {
          FlexWeight: 1;
        }
      }
    }
  }
}
