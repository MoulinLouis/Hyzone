$C = "../Common.ui";

Button {
  Anchor: (Height: 34, Left: 0, Right: 0, Top: 2);
  LayoutMode: Left;
  Padding: (Left: 8, Right: 8, Top: 3, Bottom: 3);
  Style: ButtonStyle(
    Default: (Background: #ffffff(0.03)),
    Hovered: (Background: #2d3f50),
    Pressed: (Background: #ffffff(0.03)),
    Sounds: $C.@ButtonSounds,
  );

  ItemIcon #BlockIcon {
    Anchor: (Width: 28, Height: 28);
    ShowItemTooltip: true;
  }

  Group {
    Anchor: (Width: 8);
  }

  Label #BlockName {
    Anchor: (Top: 0, Bottom: 0);
    Style: (FontSize: 13, TextColor: #f0f4f8, VerticalAlignment: Center);
    Text: "Block Name";
  }
}
