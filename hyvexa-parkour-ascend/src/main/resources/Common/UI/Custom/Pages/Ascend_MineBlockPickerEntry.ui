$C = "../Common.ui";

Button {
  Anchor: (Height: 32, Left: 0, Right: 0);
  LayoutMode: Left;
  Padding: (Left: 8, Right: 8, Top: 3, Bottom: 3);
  Style: ButtonStyle(
    Default: (Background: #000000(0.05)),
    Hovered: (Background: #ffffff(0.08)),
    Pressed: (Background: #ffffff(0.03)),
    Sounds: $C.@ButtonSounds,
  );

  ItemIcon #BlockIcon {
    Anchor: (Width: 26, Height: 26);
    ShowItemTooltip: true;
  }

  Group {
    Anchor: (Width: 8);
  }

  Label #BlockName {
    Anchor: (Top: 0, Bottom: 0);
    Style: (FontSize: 13, TextColor: #cfd7dc, VerticalAlignment: Center);
    Text: "Block Name";
  }
}
